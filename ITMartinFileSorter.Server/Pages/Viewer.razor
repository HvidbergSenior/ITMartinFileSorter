@page "/viewer"
@using Microsoft.AspNetCore.WebUtilities
@using System.Timers
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Infrastructure.FileSystem

@inject NavigationManager Navigation

<div class="viewer-page"
     style="padding:20px; background:black; min-height:100vh; color:white;">

    <div class="viewer-toolbar mb-3 d-flex gap-2 align-items-center">
        <button class="btn btn-secondary"
                @onclick="PlayPrevious"
                disabled="@(Playlist.Count <= 1)">
            ⬅ Previous
        </button>

        <button class="btn btn-danger"
                @onclick="PlayNext"
                disabled="@(Playlist.Count <= 1)">
            Next ➜
        </button>

        @if (Playlist.Any())
        {
            <span class="ms-3">
                @(CurrentIndex + 1) / @Playlist.Count
            </span>
        }
    </div>

    @if (!string.IsNullOrEmpty(FilePath))
    {
        <div class="mb-3">
            <strong>@Path.GetFileName(FilePath)</strong>
        </div>
    }

    @if (!Playlist.Any())
    {
        <div class="alert alert-warning">
            No supported media found in this folder.
        </div>
    }
    else if (!string.IsNullOrEmpty(WebPath))
    {
        @if (IsVideo)
        {
            <video @key="WebPath"
                   width="100%"
                   style="max-height:80vh"
                   controls
                   autoplay
                   @onended="PlayNext">
                <source src="@WebPath" type="video/mp4" />
            </video>
        }
        else
        {
            <img @key="WebPath"
                 src="@WebPath"
                 class="img-fluid rounded shadow"
                 style="max-height:80vh; max-width:100%;" />
        }
    }

</div>

@code {
    private string FilePath = "";
    private string WebPath = "";
    private bool IsVideo;

    private List<string> Playlist = new();
    private int CurrentIndex = 0;

    private Timer? _slideshowTimer;

    protected override void OnInitialized()
    {
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = QueryHelpers.ParseQuery(uri.Query);

            if (!query.TryGetValue("path", out var path))
                return;

            FilePath = Uri.UnescapeDataString(path!);

            var folder = Path.GetDirectoryName(FilePath);

            if (string.IsNullOrWhiteSpace(folder) || !Directory.Exists(folder))
                return;

            Playlist = Directory
                .EnumerateFiles(folder)
                .Where(FileScanner.IsSupportedMedia)
                .OrderBy(x => x)
                .ToList();

            CurrentIndex = Playlist.FindIndex(f =>
                string.Equals(f, FilePath, StringComparison.OrdinalIgnoreCase));

            if (CurrentIndex < 0)
                CurrentIndex = 0;

            LoadCurrentMedia();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Viewer init error: {ex}");
        }
    }

    private void LoadCurrentMedia()
    {
        StopTimer();

        if (!Playlist.Any())
        {
            WebPath = "";
            return;
        }

        if (CurrentIndex < 0 || CurrentIndex >= Playlist.Count)
            CurrentIndex = 0;

        FilePath = Playlist[CurrentIndex];

        // Build relative path from "Exported"
        var exportedIndex = FilePath.IndexOf("Exported", StringComparison.OrdinalIgnoreCase);

        if (exportedIndex < 0)
        {
            WebPath = "";
            return;
        }

        var relativePath = FilePath[(exportedIndex + "Exported".Length)..]
            .TrimStart('\\', '/')
            .Replace("\\", "/");

        WebPath = $"/libraryfiles/{relativePath}";

        var ext = Path.GetExtension(FilePath).ToLowerInvariant();

        IsVideo = FileScanner.VideoExtensions.Contains(ext);

        Console.WriteLine("===== VIEWER DEBUG =====");
        Console.WriteLine($"FilePath: {FilePath}");
        Console.WriteLine($"WebPath: {WebPath}");
        Console.WriteLine($"IsVideo: {IsVideo}");

        if (!IsVideo && Playlist.Count > 1)
            StartTimer();

        InvokeAsync(StateHasChanged);
    }

    private void StartTimer()
    {
        _slideshowTimer = new Timer(4000);

        _slideshowTimer.Elapsed += (_, _) =>
        {
            InvokeAsync(PlayNext);
        };

        _slideshowTimer.AutoReset = false;
        _slideshowTimer.Start();
    }

    private void StopTimer()
    {
        _slideshowTimer?.Stop();
        _slideshowTimer?.Dispose();
        _slideshowTimer = null;
    }

    private void PlayNext()
    {
        if (Playlist.Count <= 1)
            return;

        CurrentIndex++;

        if (CurrentIndex >= Playlist.Count)
            CurrentIndex = 0;

        LoadCurrentMedia();
    }

    private void PlayPrevious()
    {
        if (Playlist.Count <= 1)
            return;

        CurrentIndex--;

        if (CurrentIndex < 0)
            CurrentIndex = Playlist.Count - 1;

        LoadCurrentMedia();
    }

    public void Dispose()
    {
        StopTimer();
    }
}