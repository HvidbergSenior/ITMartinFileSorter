@page "/viewer"
@using Microsoft.AspNetCore.WebUtilities
@using ITMartinFileSorter.Infrastructure.FileSystem
@using ITMartinFileSorter.Application.Services

@inject NavigationManager Navigation
@inject SubtitleService SubtitleService

<div class="viewer-page">

    <ActionButtonBar>
        <button class="btn btn-outline-light"
                @onclick="GoHome">
            🏠 Home
        </button>

        <button class="btn btn-outline-secondary"
                @onclick="GoToFolder">
            📁 Folder
        </button>

        <button class="btn btn-secondary"
                @onclick="PlayPrevious"
                disabled="@(Playlist.Count <= 1)">
            ⬅ Previous
        </button>

        <button class="btn btn-danger"
                @onclick="PlayNext"
                disabled="@(Playlist.Count <= 1)">
            Next ➜
        </button>
    </ActionButtonBar>

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <EmptyState
            Message="@StatusMessage"
            Type="info" />
    }

    @if (IsGeneratingSubtitles)
    {
        <ProgressPanel
            Title="Generating subtitles..."
            Current="@_elapsedSeconds"
            Total="100"
            Percent="@_elapsedSeconds"
            CurrentItem="@ElapsedText" />
    }

    @if (!string.IsNullOrEmpty(FilePath))
    {
        <ContentCard Title="@Path.GetFileName(FilePath)">
            @if (IsVideo)
            {
                <video class="viewer-video"
                       width="100%"
                       controls
                       autoplay>
                    <source src="@WebPath" type="video/mp4" />
                </video>
            }
            else
            {
                <img class="viewer-image"
                     src="@WebPath" />
            }
        </ContentCard>
    }

</div>

@code {
    private string FilePath = "";
    private string WebPath = "";
    private string SubtitlePath = "";
    private string StatusMessage = "";

    private bool IsVideo;
    private bool IsGeneratingSubtitles;

    private List<string> Playlist = new();
    private int CurrentIndex = 0;
    private System.Timers.Timer? _subtitleTimer;
    private int _elapsedSeconds;
    private string ElapsedText => TimeSpan
        .FromSeconds(_elapsedSeconds)
        .ToString(@"mm\:ss");


    protected override void OnParametersSet()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("path", out var path))
            return;

        FilePath = Uri.UnescapeDataString(path!);

        var folder = Path.GetDirectoryName(FilePath);

        if (string.IsNullOrWhiteSpace(folder) || !Directory.Exists(folder))
            return;

        Playlist = FilterConvertedFiles(
                Directory
                    .EnumerateFiles(folder)
                    .Where(FileScanner.IsSupportedMedia)
                    .OrderBy(x => x))
            .ToList();
        
        CurrentIndex = Playlist.FindIndex(f =>
            string.Equals(f, FilePath, StringComparison.OrdinalIgnoreCase));

        if (CurrentIndex < 0)
            CurrentIndex = 0;

        LoadCurrentMedia();
    }

    private void LoadCurrentMedia()
    {
        FilePath = Playlist[CurrentIndex];

        var exportedIndex = FilePath.IndexOf("Exported",
            StringComparison.OrdinalIgnoreCase);

        var relativePath = FilePath[(exportedIndex + "Exported".Length)..]
            .TrimStart('\\', '/')
            .Replace("\\", "/");

        WebPath = $"/libraryfiles/{relativePath}";

        IsVideo = FileScanner.IsVideo(FilePath);

        LoadExistingSubtitle();
    }

    private void LoadExistingSubtitle()
    {
        var subtitleFile = Path.ChangeExtension(FilePath, ".da.vtt");

        if (!File.Exists(subtitleFile))
        {
            SubtitlePath = "";
            return;
        }

        var exportedIndex = subtitleFile.IndexOf("Exported",
            StringComparison.OrdinalIgnoreCase);

        var relativePath =
            subtitleFile[(exportedIndex + "Exported".Length)..]
            .TrimStart('\\', '/')
            .Replace("\\", "/");

        SubtitlePath = $"/libraryfiles/{relativePath}";
    }

    private async Task GenerateQuickSubtitles()
    {
        await GenerateSubtitles(false);
    }

    private async Task GeneratePremiumSubtitles()
    {
        await GenerateSubtitles(true);
    }

    private async Task GenerateSubtitles(bool isLongFilm)
    {
        if (!IsVideo)
            return;

        IsGeneratingSubtitles = true;

        StatusMessage = isLongFilm
            ? "🎬 Generating premium subtitles for long film..."
            : "🇩🇰 Generating quick subtitles...";

        StateHasChanged();
        _elapsedSeconds = 0;
        StartSubtitleTimer();

        var result =
            await SubtitleService.GenerateDanishSubtitlesAsync(
                FilePath,
                isLongFilm);

        StopSubtitleTimer();

        if (!string.IsNullOrWhiteSpace(result))
        {
            LoadExistingSubtitle();
            StatusMessage = "Subtitles ready 🇩🇰";
        }
        else
        {
            StatusMessage = "Subtitle generation failed";
        }

        IsGeneratingSubtitles = false;

        await InvokeAsync(StateHasChanged);
    }
    private void StartSubtitleTimer()
    {
        StopSubtitleTimer();

        _subtitleTimer = new System.Timers.Timer(1000);

        _subtitleTimer.Elapsed += async (_, _) =>
        {
            _elapsedSeconds++;

            await InvokeAsync(StateHasChanged);
        };

        _subtitleTimer.AutoReset = true;
        _subtitleTimer.Start();
    }

    private void StopSubtitleTimer()
    {
        _subtitleTimer?.Stop();
        _subtitleTimer?.Dispose();
        _subtitleTimer = null;
    }


    private void PlayNext()
    {
        if (Playlist.Count <= 1)
            return;

        CurrentIndex++;

        if (CurrentIndex >= Playlist.Count)
            CurrentIndex = 0;

        LoadCurrentMedia();
    }

    private void PlayPrevious()
    {
        if (Playlist.Count <= 1)
            return;

        CurrentIndex--;

        if (CurrentIndex < 0)
            CurrentIndex = Playlist.Count - 1;

        LoadCurrentMedia();
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/library", forceLoad: true);
    }

    private void GoToFolder()
    {
        var folder = Path.GetDirectoryName(FilePath);

        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(folder!)}",
            forceLoad: true);
    }
    private IEnumerable<string> FilterConvertedFiles(
        IEnumerable<string> files)
    {
        var list = files.ToList();

        var convertedBaseNames = list
            .Where(f =>
                Path.GetFileNameWithoutExtension(f)
                    .EndsWith("_fixed",
                        StringComparison.OrdinalIgnoreCase))
            .Select(f =>
            {
                var name = Path.GetFileNameWithoutExtension(f);
                return name[..^6]; // remove "_fixed"
            })
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return list.Where(file =>
        {
            var ext = Path.GetExtension(file).ToLowerInvariant();
            var name = Path.GetFileNameWithoutExtension(file);

            // hide original if converted exists
            if (ext != ".mp4" &&
                convertedBaseNames.Contains(name))
                return false;

            return true;
        });
    }
}
