@page "/library"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Entities
@inject IFileScanner FileScanner
@inject ThumbnailService ThumbnailService
@inject NavigationManager Navigation

<div class="library-page"
     style="background:black; min-height:100vh; color:white;">
    <div style="background:red; color:white; padding:20px;">
        TEST BACKGROUND
    </div>
    <div class="library-header">
        <h1>🎬 My Media Library</h1>
        <p>Your movies, photos and memories</p>
    </div>

    <div class="library-toolbar">
        <input class="search-box"
               @bind="LibraryPath"
               placeholder="Folder path..." />

        <button class="load-btn" @onclick="LoadLibrary">
            Refresh
        </button>
    </div>

    <div class="media-grid">
        @foreach (var file in Files)
        {
            <div class="media-card"
                 @onclick="() => OpenFile(file)">

                @if (!string.IsNullOrEmpty(file.ThumbnailPath))
                {
                    <img src="@file.ThumbnailPath"
                         class="media-thumb" />
                }
                else
                {
                    <div class="media-placeholder">
                        🎥
                    </div>
                }

                <div class="media-overlay">
                    ▶ Play
                </div>

                <div class="media-info">
                    <div class="media-title">@file.FileName</div>
                    <div class="media-type">@file.MainCategory</div>
                </div>
            </div>
        }
    </div>

</div>


@code {
    private string LibraryPath =
        @"C:\Users\hvidb\Desktop\BillederIphone\Film\Exported\Organized";

    private List<MediaFile> Files = new();

    protected override void OnInitialized()
    {
        LoadLibrary();
    }

    private void LoadLibrary()
    {
        if (!Directory.Exists(LibraryPath))
            return;

        Files = FileScanner.ScanFolder(LibraryPath).ToList();

        foreach (var file in Files)
        {
            file.ThumbnailPath = ThumbnailService.GenerateThumbnail(file);
        }

        StateHasChanged();
    }

    private void OpenFile(MediaFile file)
    {
        var path = file.FullPath;

        var mp4Path = Path.ChangeExtension(path, ".mp4");

        if (File.Exists(mp4Path))
            path = mp4Path;

        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(path)}");
    }
}