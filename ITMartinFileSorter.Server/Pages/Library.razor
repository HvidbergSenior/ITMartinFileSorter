@page "/library"
@using Microsoft.AspNetCore.WebUtilities
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Infrastructure.FileSystem

@inject NavigationManager Navigation
@inject IFileScanner Scanner
@inject ThumbnailService ThumbnailService
@inject IConfiguration Configuration

<div class="library-page">

    <div class="library-header mb-4">
        <h1>🎬 My Media Library</h1>
        <p>Browse your memories like Netflix</p>
    </div>

    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-outline-light" @onclick="GoHome">🏠 Home</button>
        <button class="btn btn-secondary" @onclick="GoBack" disabled="@(!CanGoBack)">⬅ Back</button>
    </div>

    <div class="mb-3">
        <strong>📍 Current folder:</strong>
        <div>@CurrentPath</div>
    </div>

    <div class="mb-4 d-flex gap-2 search-wrapper">
        <input type="text"
               class="form-control search-container"
               placeholder="🔍 Search entire library..."
               value="@SearchText"
               @oninput="OnSearchChanged" />
        <button class="btn btn-outline-light" @onclick="ClearSearch">✖</button>
    </div>

    <div class="mb-3 d-flex gap-2 flex-wrap">
        <button class="btn @(SelectedFilter == "all" ? "btn-primary" : "btn-outline-light")"
                @onclick='() => SetFilter("all")'>All</button>
        <button class="btn @(SelectedFilter == "video" ? "btn-primary" : "btn-outline-light")"
                @onclick='() => SetFilter("video")'>🎬 Videos</button>
        <button class="btn @(SelectedFilter == "image" ? "btn-primary" : "btn-outline-light")"
                @onclick='() => SetFilter("image")'>🖼️ Photos</button>
        <button class="btn @(SelectedFilter == "document" ? "btn-primary" : "btn-outline-light")"
                @onclick='() => SetFilter("document")'>📄 Documents</button>
    </div>

    <div class="mb-2 text-muted">
        Showing @FilteredFolders.Count folders and @FilteredFiles.Count files
    </div>

    @if (!FilteredFolders.Any() && !FilteredFiles.Any())
    {
        <div class="alert alert-warning">No matching media found.</div>
    }

    <h3>📁 Folders</h3>
    <div class="folder-grid">
        @foreach (var folder in FilteredFolders)
        {
            <div class="folder-card"
                 role="button"
                 tabindex="0"
                 @onclick="@(() => OpenFolder(folder.FullPath))">
                <div class="folder-icon">📁</div>
                <div class="folder-name">@folder.Name</div>
                <div class="folder-count">@folder.FileCount files</div>
            </div>
        }
    </div>

    <h3>🎥 Media</h3>
    <div class="media-grid">
        @foreach (var file in FilteredFiles)
        {
            <div class="media-card"
                 role="button"
                 tabindex="0"
                 @onclick="@(() => OpenFile(file))">

                @if (!string.IsNullOrEmpty(file.ThumbnailPath))
                {
                    <img src="@file.ThumbnailPath" class="media-thumb" />
                }
                else
                {
                    <div class="media-placeholder">
                        @(file.Type == MediaType.Video ? "🎬" : "🖼️")
                    </div>
                }

                <div class="media-title">@Path.GetFileName(file.FullPath)</div>
            </div>
        }
    </div>
</div>

@code {
    private string RootPath = "";
    private string CurrentPath = "";
    private string SearchText = "";
    private string SelectedFilter = "all";

    private List<FolderItem> Folders = new();
    private List<MediaFile> Files = new();
    private List<FolderItem> SearchFolders = new();
    private List<MediaFile> SearchFiles = new();

    private string? _lastUri;

    private bool IsSearchActive => !string.IsNullOrWhiteSpace(SearchText);

    private bool CanGoBack =>
        !string.Equals(CurrentPath, RootPath, StringComparison.OrdinalIgnoreCase);

    private List<FolderItem> FilteredFolders =>
        IsSearchActive ? SearchFolders : Folders;

    private List<MediaFile> FilteredFiles =>
        (IsSearchActive ? SearchFiles : Files)
            .Where(MatchesSelectedFilter)
            .ToList();

    protected override void OnAfterRender(bool firstRender)
    {
        if (_lastUri == Navigation.Uri)
            return;

        _lastUri = Navigation.Uri;
        LoadFromUrl();
        StateHasChanged();
    }

    private void LoadFromUrl()
    {
        var libraryRoot = Configuration["MediaSettings:LibraryRoot"];

        if (string.IsNullOrWhiteSpace(libraryRoot))
        {
            libraryRoot = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.MyPictures),
                "FileSorter");
        }

        RootPath = Path.Combine(libraryRoot, "Exported", "Organized");

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("path", out var path))
        {
            var requestedPath = Uri.UnescapeDataString(path!);
            if (Directory.Exists(requestedPath))
            {
                LoadFolder(requestedPath);
                return;
            }
        }

        LoadFolder(RootPath);
    }

    private void LoadFolder(string path)
    {
        try
        {
            CurrentPath = path;
            SearchText = "";
            SearchFolders.Clear();
            SearchFiles.Clear();

            if (!Directory.Exists(path))
            {
                Folders.Clear();
                Files.Clear();
                return;
            }

            Folders = Directory
                .EnumerateDirectories(path)
                .Select(CreateFolderItem)
                .OrderBy(x => x.Name)
                .ToList();

            Files = Directory
                .EnumerateFiles(path, "*.*", SearchOption.TopDirectoryOnly)
                .Where(FileScanner.IsSupportedMedia)
                .Select(CreateMediaFile)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine("===== LOAD FOLDER ERROR =====");
            Console.WriteLine(ex);
        }
    }

    private FolderItem CreateFolderItem(string folder) => new()
    {
        Name = Path.GetFileName(folder),
        FullPath = folder,
        FileCount = Directory
            .EnumerateFiles(folder, "*.*", SearchOption.AllDirectories)
            .Count(FileScanner.IsSupportedMedia)
    };

    private MediaFile CreateMediaFile(string file)
    {
        var info = new FileInfo(file);

        var type = FileScanner.IsVideo(file)
            ? MediaType.Video
            : FileScanner.IsImage(file)
                ? MediaType.Image
                : MediaType.Document;

        var mediaFile = new MediaFile(
            file,
            info.LastWriteTimeUtc,
            type,
            info.Length);

        if (type == MediaType.Image)
        {
            try
            {
                mediaFile.ThumbnailPath =
                    ThumbnailService.GenerateThumbnail(mediaFile);
            }
            catch
            {
                mediaFile.ThumbnailPath = null;
            }
        }

        return mediaFile;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? "";

        if (!IsSearchActive)
        {
            SearchFolders.Clear();
            SearchFiles.Clear();
            return;
        }

        RunRecursiveSearch();
    }

    private void RunRecursiveSearch()
    {
        SearchFolders = Directory
            .EnumerateDirectories(CurrentPath, "*", SearchOption.AllDirectories)
            .Where(folder =>
                Path.GetFileName(folder)
                    .Contains(SearchText, StringComparison.OrdinalIgnoreCase))
            .Select(CreateFolderItem)
            .ToList();

        SearchFiles = Directory
            .EnumerateFiles(CurrentPath, "*.*", SearchOption.AllDirectories)
            .Where(FileScanner.IsSupportedMedia)
            .Where(file =>
                Path.GetFileName(file)
                    .Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                ||
                Path.GetExtension(file)
                    .Contains(SearchText, StringComparison.OrdinalIgnoreCase))
            .Select(CreateMediaFile)
            .ToList();
    }

    private bool MatchesSelectedFilter(MediaFile file) => SelectedFilter switch
    {
        "video" => file.Type == MediaType.Video,
        "image" => file.Type == MediaType.Image,
        "document" => file.Type == MediaType.Document,
        _ => true
    };

    private void SetFilter(string filter)
    {
        SelectedFilter = filter;
    }

    private void ClearSearch()
    {
        SearchText = "";
        SearchFolders.Clear();
        SearchFiles.Clear();
    }

    private void OpenFolder(string path)
    {
        Navigation.NavigateTo($"/library?path={Uri.EscapeDataString(path)}");
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/library");
    }

    private void GoBack()
    {
        var parent = Directory.GetParent(CurrentPath);

        if (parent == null)
        {
            Navigation.NavigateTo("/library");
            return;
        }

        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(parent.FullName)}");
    }

    private void OpenFile(MediaFile file)
    {
        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(file.FullPath)}",
            forceLoad: true);
    }
}