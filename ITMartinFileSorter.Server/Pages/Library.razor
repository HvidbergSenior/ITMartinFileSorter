@page "/library"
@using Microsoft.AspNetCore.WebUtilities
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Infrastructure.FileSystem

@inject NavigationManager Navigation
@inject IFileScanner Scanner
@inject ThumbnailService ThumbnailService
@inject IConfiguration Configuration

<div class="library-page">

    <div class="library-header mb-4">
        <h1>🎬 My Media Library</h1>
        <p>Browse your memories like Netflix</p>
    </div>

    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-outline-light" @onclick="GoHome">
            🏠 Home
        </button>

        <button class="btn btn-secondary"
                @onclick="GoBack"
                disabled="@(!CanGoBack)">
            ⬅ Back
        </button>
    </div>

    <div class="mb-3">
        <strong>📍 Current folder:</strong>
        <div>@CurrentPath</div>
    </div>

    @if (!Folders.Any() && !Files.Any())
    {
        <div class="alert alert-warning">
            No media found in this folder.
        </div>
    }

    <h3>📁 Folders</h3>
    <div class="folder-grid">
        @foreach (var folder in Folders)
        {
            <div class="folder-card"
                 role="button"
                 tabindex="0"
                 style="cursor:pointer;"
                 @onclick="@(() => OpenFolder(folder.FullPath))">
                <div class="folder-icon">📁</div>
                <div class="folder-name">@folder.Name</div>
                <div class="folder-count">@folder.FileCount files</div>
            </div>
        }
    </div>

    <h3>🎥 Media</h3>

    <div class="media-grid">
        @foreach (var file in Files)
        {
            <div class="media-card"
                 role="button"
                 tabindex="0"
                 @onclick="@(() => OpenFile(file))">

                @if (!string.IsNullOrEmpty(file.ThumbnailPath))
                {
                    <img src="@file.ThumbnailPath"
                         class="media-thumb" />
                }
                else
                {
                    <div class="media-placeholder">
                        @(file.Type == MediaType.Video ? "🎬" : "🖼️")
                    </div>
                }

                <div class="media-title">
                    @Path.GetFileName(file.FullPath)
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string RootPath = "";
    private string CurrentPath = "";

    private List<FolderItem> Folders = new();
    private List<MediaFile> Files = new();

    private string? _lastUri;

    private bool CanGoBack =>
        !string.Equals(CurrentPath, RootPath, StringComparison.OrdinalIgnoreCase);

    protected override void OnAfterRender(bool firstRender)
    {
        if (_lastUri == Navigation.Uri)
            return;

        _lastUri = Navigation.Uri;

        Console.WriteLine("===== URL CHANGED =====");
        Console.WriteLine(Navigation.Uri);

        LoadFromUrl();

        StateHasChanged();
    }

    private void LoadFromUrl()
    {
        var libraryRoot = Configuration["MediaSettings:LibraryRoot"];

        if (string.IsNullOrWhiteSpace(libraryRoot))
        {
            libraryRoot = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.MyPictures),
                "FileSorter");
        }

        RootPath = Path.Combine(
            libraryRoot,
            "Exported",
            "Organized");

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("path", out var path))
        {
            var requestedPath = Uri.UnescapeDataString(path!);

            if (Directory.Exists(requestedPath))
            {
                LoadFolder(requestedPath);
                return;
            }
        }

        LoadFolder(RootPath);
    }

    private void LoadFolder(string path)
{
    try
    {
        Folders.Clear();
        Files.Clear();

        CurrentPath = path;

        if (!Directory.Exists(path))
            return;

        Folders = Directory
            .EnumerateDirectories(path)
            .Select(folder => new FolderItem
            {
                Name = Path.GetFileName(folder),
                FullPath = folder,
                FileCount = Directory
                    .EnumerateFiles(folder, "*.*", SearchOption.AllDirectories)
                    .Count(FileScanner.IsSupportedMedia)
            })
            .OrderBy(x => x.Name)
            .ToList();

        Files = Directory
            .EnumerateFiles(path, "*.*", SearchOption.TopDirectoryOnly)
            .Where(FileScanner.IsSupportedMedia)
            .Select(file =>
            {
                var info = new FileInfo(file);

                var type = FileScanner.IsVideo(file)
                    ? MediaType.Video
                    : FileScanner.IsImage(file)
                        ? MediaType.Image
                        : MediaType.Document;

                var mediaFile = new MediaFile(
                    file,
                    info.LastWriteTimeUtc,
                    type,
                    info.Length);

                // Only generate thumbnails for images for now
                if (type == MediaType.Image)
                {
                    try
                    {
                        mediaFile.ThumbnailPath =
                            ThumbnailService.GenerateThumbnail(mediaFile);
                    }
                    catch
                    {
                        mediaFile.ThumbnailPath = null;
                    }
                }

                return mediaFile;
            })
            .ToList();

        Console.WriteLine($"FILES SHOWN = {Files.Count}");
    }
    catch (Exception ex)
    {
        Console.WriteLine("===== LOAD FOLDER ERROR =====");
        Console.WriteLine(ex);
    }
}

    private void OpenFolder(string path)
    {
        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(path)}",
            forceLoad: false);
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/library", forceLoad: false);
    }

    private void GoBack()
    {
        var parent = Directory.GetParent(CurrentPath);

        if (parent == null)
        {
            Navigation.NavigateTo("/library");
            return;
        }

        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(parent.FullName)}",
            forceLoad: false);
    }

    private void OpenFile(MediaFile file)
    {
        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(file.FullPath)}",
            forceLoad: true);
    }
}
