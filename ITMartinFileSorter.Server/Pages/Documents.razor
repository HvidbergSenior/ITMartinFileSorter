@page "/documents"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<h3>Documents</h3>

@if (!DocumentFiles.Any())
{
    <div class="alert alert-info">No document files found.</div>
    <button class="btn btn-primary" @onclick="GoNext">Back to Overview</button>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-3">
        @foreach (var group in SubGroups.Keys)
        {
            <div class="all-files-card p-3 text-center" style="width:200px; cursor:pointer">
                <strong>@group</strong><br />@SubGroups[group].Count files
                <div class="mt-1">
                    <button class="btn btn-sm btn-success" @onclick="() => KeepAllInGroup(group)">Keep All</button>
                </div>
            </div>
        }
    </div>

    @foreach (var group in SubGroups.Keys)
    {
        <div class="mb-3">
            <h5>@group</h5>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var file in SubGroups[group])
                {
                    <div class="file-card text-center p-2" style="width:150px; border:1px solid #ccc;">
                        <div style="font-size:0.75em;">@file.FileName</div>
                        <div class="mt-1">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => Keep(file)">Keep</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(file)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <button class="btn btn-success mt-3" @onclick="Accept">Accept & Continue</button>
}

@code {
    List<MediaFile> DocumentFiles => DuplicateService.AllFiles
        .Where(f => f.MainCategory == MediaMainCategory.Document)
        .ToList();

    Dictionary<string, List<MediaFile>> SubGroups = new();

    protected override void OnInitialized()
    {
        SubGroups = DocumentFiles
            .GroupBy(f => f.Extension.ToLower())
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void KeepAllInGroup(string key)
    {
        foreach (var file in SubGroups[key])
            file.Keep = true;
    }

    void Keep(MediaFile file) => file.Keep = true;

    void Delete(MediaFile file)
    {
        file.Keep = false;
        DuplicateService.AllFiles.Remove(file);
        RebuildGroups();
    }

    void RebuildGroups()
    {
        SubGroups = DocumentFiles
            .GroupBy(f => f.Extension.ToLower())
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void Accept()
    {
        foreach (var file in DocumentFiles)
            file.Keep = true;

        Navigation.NavigateTo("/"); // back to overview
    }

    void GoNext() => Navigation.NavigateTo("/");
}