@page "/videos"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject VideoThumbnailService VideoThumbnailService
@inject NavigationManager Navigation

<h3>Videos</h3>

@if (!VideoFiles.Any())
{
    <div class="alert alert-info">No video files found.</div>
    <button class="btn btn-primary" @onclick="Finish">Finish</button>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-3">
        @foreach (var group in SubGroups.Keys)
        {
            <div class="all-files-card p-3 text-center" style="width:200px; cursor:pointer"
                 @onclick="() => ToggleSubGroup(group)">
                <strong>@group</strong><br />@SubGroups[group].Count files
            </div>
        }
    </div>

    @if (ExpandedSubKey != null)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            @foreach (var file in SubGroups[ExpandedSubKey])
            {
                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                    <img src="@GetThumbnail(file)" style="width:100%; height:80px; object-fit:cover;" />
                    <div style="font-size:0.75em;">@file.FileName</div>
                </div>
            }
        </div>
    }

    <button class="btn btn-success mt-3" @onclick="Accept">Accept & Finish</button>
}

@code {
    List<MediaFile> VideoFiles => DuplicateService.AllFiles
        .Where(f => f.MainCategory == MediaMainCategory.Video)
        .ToList();

    Dictionary<string, List<MediaFile>> SubGroups = new();
    string? ExpandedSubKey;

    protected override void OnInitialized()
    {
        // Group by Year-Month
        SubGroups = VideoFiles
            .GroupBy(f => $"{f.Year}-{f.Month:D2}")
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void ToggleSubGroup(string key) => ExpandedSubKey = ExpandedSubKey == key ? null : key;

    void Accept()
    {
        foreach (var file in VideoFiles) file.Keep = true;
        Finish();
    }

    void Finish()
    {
        // Optional: trigger export or continue workflow
        Navigation.NavigateTo("/");
    }

    string GetThumbnail(MediaFile file)
    {
        // IMAGE
        if (file.Type == MediaType.Image)
        {
            if (string.IsNullOrEmpty(file.WorkingPath) || !File.Exists(file.WorkingPath))
                return "_content/placeholder.png";

            return $"/api/media?path={Uri.EscapeDataString(file.WorkingPath.Replace("\\","/"))}";
        }

        // VIDEO
        if (file.Type == MediaType.Video)
        {
            try
            {
                if (string.IsNullOrEmpty(file.ThumbnailPath))
                {
                    // Generate thumbnail asynchronously
                    _ = Task.Run(() =>
                    {
                        try
                        {
                            file.ThumbnailPath = VideoThumbnailService.GenerateThumbnail(file.FullPath);
                            InvokeAsync(StateHasChanged); // Refresh UI
                        }
                        catch { }
                    });

                    return "_content/video-icon.png"; // temporary placeholder
                }

                return $"/media_temp/{file.ThumbnailPath}?t={DateTime.Now.Ticks}";
            }
            catch
            {
                return "_content/video-icon.png";
            }
        }

        return "_content/file-icon.png";
    }
}