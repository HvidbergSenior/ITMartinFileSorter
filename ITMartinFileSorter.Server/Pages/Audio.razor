@page "/audio"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<h3>Audio Files</h3>

@if (!AudioFiles.Any())
{
    <div class="alert alert-info">No audio files found.</div>
    <button class="btn btn-primary" @onclick="GoNext">Next Step</button>
}
else
{
    <div class="d-flex flex-wrap gap-3">
        @foreach (var group in AudioFiles.GroupBy(f => f.SubCategory))
        {
            <div class="all-files-card p-3 text-center" style="width:200px">
                <strong>@group.Key</strong>
                <div>@group.Count() files</div>
            </div>
        }
    </div>
    <button class="btn btn-success mt-3" @onclick="Accept">Accept & Continue</button>
}

@code {
    List<MediaFile> AudioFiles => DuplicateService.AllFiles
        .Where(f => f.MainCategory == MediaMainCategory.Audio)
        .ToList();

    void Accept()
    {
        foreach (var file in AudioFiles)
            file.Keep = true;

        GoNext();
    }

    void GoNext()
    {
        Navigation.NavigateTo(DuplicateService.AllFiles.Any(f => f.MainCategory == MediaMainCategory.Document)
            ? "/documents"
            : DuplicateService.AllFiles.Any(f => f.MainCategory == MediaMainCategory.Image)
                ? "/images"
                : DuplicateService.AllFiles.Any(f => f.MainCategory == MediaMainCategory.Video)
                    ? "/videos"
                    : "/");
    }
}