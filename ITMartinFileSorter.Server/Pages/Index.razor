@page "/"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Application.UseCases

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IFileScanner FileScanner
@inject IHashService HashService
@inject MediaCategorizer MediaCategorizer
@inject FastVideoBatchExportService VideoBatchExportService

<div class="container mt-4">

    @* ===== FOLDER INPUT ===== *@
    <div class="folder-input d-flex mb-3">
        <input type="text" @bind="FolderPath" placeholder="Enter folder path..." class="form-control me-2" />
        <button class="btn btn-primary" @onclick="ScanFolder" disabled="@IsScanning">
            @(IsScanning ? "Scanning..." : "Scan")
        </button>
    </div>

    @* ===== SCANNING PROGRESS ===== *@
    @if (IsScanning)
    {
        <div class="alert alert-info mt-2">
            <strong>Scanning folder...</strong>
            <div class="spinner-border spinner-border-sm ms-2"></div>

            <div class="progress mt-2">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width:@ScanProgressPercent%">
                    @CurrentFileIndex of @TotalFilesToScan files
                </div>
            </div>

            @if (!string.IsNullOrEmpty(CurrentFileName))
            {
                <div class="mt-1">Current: @CurrentFileName</div>
            }
        </div>
    }

    @* ===== DUPLICATE HANDLING ===== *@
    else if (!DuplicateService.DuplicatesHandled && DuplicateService.AllFiles.Any())
    {
        <div class="alert alert-warning mt-2">
            ⚠ Handle duplicates first
            <button class="btn btn-sm btn-secondary ms-2" @onclick="GoToDuplicates">
                Go to Duplicates
            </button>
        </div>
    }

    @* ===== MAIN WORKFLOW ===== *@
    else if (DuplicateService.AllFiles.Any() && DuplicateService.DuplicatesHandled)
    {
        <h4>File Summary</h4>

        <div class="d-flex gap-3 mt-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = DuplicateService.AllFiles.Where(f => f.MainCategory == cat).ToList();

                var remaining = filesInCat.Count(f => f.Status == MediaFileStatus.Initial);
                var kept = filesInCat.Count(f => f.Status == MediaFileStatus.ToKeep);

                bool clickable = remaining > 0;

                <div class="p-3 text-center"
                     style="width:150px;border-radius:5px;
                            cursor:@(clickable ? "pointer" : "not-allowed");
                            background:@GetCategoryColor(cat);
                            opacity:@(clickable ? "1" : "0.6")"
                     @onclick="() => GoToCategory(cat)">

                    <strong>@cat</strong><br />
                    @remaining remaining<br />
                    @kept kept
                </div>
            }

            <div class="p-3 text-center" style="width:150px;border:1px solid #ccc;">
                <strong>Total</strong><br />
                @DuplicateService.AllFiles.Count files<br />
                @FormatSize(DuplicateService.AllFiles.Sum(f => f.SizeBytes))
            </div>
        </div>

        @* ===== FINAL ACTIONS ===== *@
        @if (AllCategoriesHandled)
        {
            <div class="mt-4 d-flex gap-2">

                <button class="btn btn-success" @onclick="GoToExport">
                    Export Organized Files
                </button>

                <button class="btn btn-danger"
                        disabled="@IsConvertingVideos"
                        @onclick="ConvertAllVideos">

                    @if (IsConvertingVideos)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <div>Converting videos...</div>
                    }
                    else
                    {
                        <span>Convert ALL Videos → MP4</span>
                    }
                </button>

            </div>

            @* ===== VIDEO PROGRESS ===== *@
            @if (IsConvertingVideos)
            {
                <div class="alert alert-info mt-3">

                    <div class="d-flex align-items-center gap-2">
                        <strong>Converting videos...</strong>
                        <div class="spinner-border spinner-border-sm"></div>
                    </div>

                    <div class="mt-2">
                        Processing @ProcessedVideos of @TotalVideos
                    </div>

                    <div class="progress mt-2">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             style="width:@ProgressPercent%">
                            @ProgressPercent%
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(CurrentVideoName))
                    {
                        <div class="mt-1">Current: @CurrentVideoName</div>
                    }

                </div>
            }

            @if (VideoConversionDone)
            {
                <div class="alert alert-success mt-2">
                    Video conversion complete ✔
                </div>
            }
        }
    }

</div>

@code {

    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    int CurrentFileIndex = 0;
    int TotalFilesToScan = 0;
    string CurrentFileName = "";

    bool IsConvertingVideos = false;
    bool VideoConversionDone = false;

    int TotalVideos = 0;
    int ProcessedVideos = 0;
    string CurrentVideoName = "";

    readonly MediaMainCategory[] CategoryOrder =
    {
        MediaMainCategory.Audio,
        MediaMainCategory.Document,
        MediaMainCategory.Image,
        MediaMainCategory.Video
    };

    bool AllCategoriesHandled =>
        CategoryOrder.All(cat =>
            !DuplicateService.AllFiles.Any(f =>
                f.MainCategory == cat &&
                f.Status == MediaFileStatus.Initial));

    int ScanProgressPercent =>
        TotalFilesToScan == 0 ? 0 :
        (int)((double)CurrentFileIndex / TotalFilesToScan * 100);

    int ProgressPercent =>
        TotalVideos == 0 ? 0 :
        (int)((double)ProcessedVideos / TotalVideos * 100);

    string GetCategoryColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "#28a745",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#ffc107",
        MediaMainCategory.Video => "#dc3545",
        _ => "#6c757d"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    void GoToCategory(MediaMainCategory cat)
    {
        if (!DuplicateService.AllFiles.Any(f =>
            f.MainCategory == cat &&
            f.Status == MediaFileStatus.Initial))
            return;

        Navigation.NavigateTo($"/category-step/{cat.ToString().ToLower()}");
    }

    void GoToDuplicates() => Navigation.NavigateTo("/duplicates");
    void GoToExport() => Navigation.NavigateTo("/export");

    async Task ScanFolder()
    {
        if (string.IsNullOrWhiteSpace(FolderPath) || !Directory.Exists(FolderPath))
            return;

        IsScanning = true;
        DuplicateService.AllFiles.Clear();

        await InvokeAsync(StateHasChanged);

        try
        {
            var scanned = FileScanner.ScanFolder(FolderPath).ToList();

            foreach (var file in scanned)
            {
                file.WorkingPath = file.FullPath;
                file.Status = MediaFileStatus.Initial;

                MediaCategorizer.Categorize(file);
            }

            DuplicateService.AllFiles = scanned;
            DuplicateService.DuplicatesHandled = false;
            DuplicateService.NotifyStateChanged();
        }
        finally
        {
            IsScanning = false;
        }
    }

    async Task ConvertAllVideos()
    {
        IsConvertingVideos = true;
        VideoConversionDone = false;

        var videos = DuplicateService.AllFiles
            .Where(f =>
                f.MainCategory == MediaMainCategory.Video &&
                f.Status != MediaFileStatus.ToDelete)
            .Select(f => f.FullPath)
            .Where(p => Path.GetExtension(p).ToLower() != ".mp4")
            .ToList();

        TotalVideos = videos.Count;
        ProcessedVideos = 0;

        await InvokeAsync(StateHasChanged);

        try
        {
            foreach (var video in videos)
            {
                CurrentVideoName = Path.GetFileName(video);

                await VideoBatchExportService.ConvertAllVideosAsync(
                    new[] { video },
                    FolderPath
                );

                ProcessedVideos++;
                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            IsConvertingVideos = false;
            VideoConversionDone = true;
        }
    }
}