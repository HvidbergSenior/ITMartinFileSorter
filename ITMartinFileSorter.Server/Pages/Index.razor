@page "/"
@inject NavigationManager Navigation

@using ITMartin.Shared.UI.Components

<div class="index-page">

    <SectionTitle Title="ITMartin Suite" />

    <div class="main-category-row mt-4">

        <ContentCard>
            <h4>🎬 FileSorter</h4>
            <p>Organize and export media files</p>

            <button class="btn btn-primary mt-3"
                    @onclick="GoToFileSorter">
                Open
            </button>
        </ContentCard>

        <ContentCard>
            <h4>🎵 Chord Finder</h4>
            <p>Detect chords from MP3 files</p>

            <button class="btn btn-secondary mt-3"
                    disabled>
                Coming Soon
            </button>
        </ContentCard>

        <ContentCard>
            <h4>📦 Inventory</h4>
            <p>Manage books, films and stock</p>

            <button class="btn btn-secondary mt-3"
                    disabled>
                Coming Soon
            </button>
        </ContentCard>

    </div>

</div>

@code {
    private void GoToFileSorter()
    {
        Navigation.NavigateTo("/filesorter");
    }
}