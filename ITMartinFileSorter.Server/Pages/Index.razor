@page "/"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IFileScanner FileScanner
@inject IHashService HashService
@inject MediaCategorizer MediaCategorizer
@inject VideoConverterService VideoConverterService

<div class="container mt-4">

    @* FOLDER INPUT ALWAYS VISIBLE *@
    <div class="folder-input d-flex mb-3">
        <input type="text" @bind="FolderPath" placeholder="Enter folder path..." class="form-control me-2" />
        <button class="btn btn-primary" @onclick="ScanFolder" disabled="@IsScanning">
            @(IsScanning ? "Scanning..." : "Scan")
        </button>
    </div>

    @* SCANNING PROGRESS *@
    @if (IsScanning)
    {
        <div class="alert alert-info mt-2">
            <div class="d-flex align-items-center gap-2">
                <strong>Scanning folder...</strong>
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <div class="progress mt-2">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     role="progressbar"
                     style="width:@ScanProgressPercent%"
                     aria-valuenow="@ScanProgressPercent"
                     aria-valuemin="0" aria-valuemax="100">
                    @CurrentFileIndex of @TotalFilesToScan files
                </div>
            </div>

            @if (!string.IsNullOrEmpty(CurrentFileName))
            {
                <div class="mt-1">Current: @CurrentFileName</div>
            }
        </div>
    }

    @* DUPLICATE HANDLING REQUIRED *@
    else if (!DuplicateService.DuplicatesHandled && DuplicateService.AllFiles.Any())
    {
        <div class="alert alert-warning mt-2">
            ⚠ You must handle duplicates before continuing
            <button class="btn btn-sm btn-secondary ms-2" @onclick="GoToDuplicates">
                Go to Duplicates
            </button>
        </div>
    }

    @* MAIN CATEGORY BOXES AFTER DUPLICATES *@
    else if (DuplicateService.AllFiles.Any() && DuplicateService.DuplicatesHandled)
    {
        <h4>File Summary</h4>

        <div class="main-category-row mt-3 d-flex gap-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = DuplicateService.AllFiles
                    .Where(f => f.MainCategory == cat)
                    .ToList();

                var remaining = filesInCat.Count(f => f.Status == MediaFileStatus.Initial);
                var kept = filesInCat.Count(f => f.Status == MediaFileStatus.ToKeep);

                bool isCurrent = remaining > 0;

                <div class="main-category-box p-3 text-center"
                     style="width:150px; border-radius:5px; cursor:@(isCurrent ? "pointer" : "not-allowed"); background:@GetCategoryColor(cat); opacity:@(isCurrent ? "1" : "0.6")"
                     @onclick="() => GoToCategory(cat)">
                    <strong>@cat</strong><br />
                    @remaining files remaining<br />
                    @kept files kept
                </div>
            }

            <div class="all-files-card p-3 text-center" style="width:150px; border:1px solid #ccc;">
                <strong>Total</strong><br />
                @DuplicateService.AllFiles.Count files<br />
                @FormatSize(DuplicateService.AllFiles.Sum(f => f.SizeBytes))
            </div>
        </div>

        @* EXPORT BUTTON WHEN ALL CATEGORIES HANDLED *@
        @if (AllCategoriesHandled)
        {
            <div class="mt-4">

                <!-- PREVIEW -->
                <ExportPreview />

                <!-- EXPORT BUTTON -->
                <div class="mt-3">
                    <button class="btn btn-success"
                            @onclick="GoToExport">
                        Export Organized Files
                    </button>
                </div>

            </div>
        }
    }
</div>

@code {
    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    int CurrentFileIndex = 0;
    int TotalFilesToScan = 0;
    string CurrentFileName = "";

    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Audio,
        MediaMainCategory.Document,
        MediaMainCategory.Image,
        MediaMainCategory.Video
    };

    bool AllCategoriesHandled =>
        CategoryOrder.All(cat =>
            !DuplicateService.AllFiles
                .Any(f => f.MainCategory == cat &&
                          f.Status == MediaFileStatus.Initial));
    int ScanProgressPercent =>
        TotalFilesToScan == 0 ? 0 : (int)((double)CurrentFileIndex / TotalFilesToScan * 100);

    string GetCategoryColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "#28a745",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#ffc107",
        MediaMainCategory.Video => "#dc3545",
        _ => "#6c757d"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.#} {sizes[order]}";
    }

    void GoToCategory(MediaMainCategory cat)
    {
        var filesRemaining = DuplicateService.AllFiles
            .Any(f => f.MainCategory == cat && f.Status == MediaFileStatus.Initial);

        if (!filesRemaining)
            return;

        var catStr = cat.ToString().ToLower();
        Navigation.NavigateTo($"/category-step/{catStr}");
    }

    void GoToDuplicates() => Navigation.NavigateTo("/duplicates");
    void GoToExport() => Navigation.NavigateTo("/export");

    void ExportFiles()
    {
        Console.WriteLine("Export triggered");
    }
    
    async Task ScanFolder()
{
    if (string.IsNullOrWhiteSpace(FolderPath) || !Directory.Exists(FolderPath))
        return;

    IsScanning = true;
    DuplicateService.AllFiles.Clear();
    CurrentFileIndex = 0;
    TotalFilesToScan = 0;
    CurrentFileName = "";

    await InvokeAsync(StateHasChanged); // show spinner immediately

    try
    {
        var scanned = await Task.Run(() =>
        {
            var result = new List<MediaFile>();

            var files = FileScanner.ScanFolder(FolderPath, (index, path) =>
            {
                CurrentFileIndex = index;
                CurrentFileName = Path.GetFileName(path);
                InvokeAsync(StateHasChanged);
            }).ToList();

            TotalFilesToScan = files.Count;

            int i = 0;

            foreach (var file in files)
            {
                i++;
                CurrentFileIndex = i;
                CurrentFileName = Path.GetFileName(file.FullPath);
                InvokeAsync(StateHasChanged);

                file.WorkingPath = file.FullPath;
                file.Status = MediaFileStatus.Initial;

                try
                {
                    var hash = HashService.ComputeHash(file.FullPath);
                    file.SetHash(hash ?? $"{file.SizeBytes}_{file.FileName}");
                }
                catch
                {
                    file.SetHash($"{file.SizeBytes}_{file.FileName}");
                }

                MediaCategorizer.Categorize(file);

                var ext = Path.GetExtension(file.FullPath).ToLowerInvariant();

                file.ThumbnailPath =
                    ext is ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".webp" or ".tiff" or ".tif"
                    ? $"/api/media?path={Uri.EscapeDataString(file.FullPath)}"
                    : "_content/file-icon.png";

                result.Add(file);
            }

            return result;
        });

        DuplicateService.AllFiles = scanned;
        DuplicateService.DuplicatesHandled = false;
        DuplicateService.NotifyStateChanged();
    }
    finally
    {
        IsScanning = false;
        await InvokeAsync(StateHasChanged);
    }
}
}