@page "/"
@using System.Linq
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IFileScanner FileScanner
@inject IHashService HashService
@inject MediaCategorizer MediaCategorizer

<div class="container mt-4">

    @if (!DuplicateService.AllFiles.Any())
    {
        <div class="folder-input d-flex mb-3">
            <input type="text" @bind="FolderPath" placeholder="Enter folder path..." class="form-control me-2" />
            <button class="btn btn-primary" @onclick="ScanFolder" disabled="@IsScanning">
                @(IsScanning ? "Scanning..." : "Scan")
            </button>
        </div>

        @if (IsScanning)
        {
            <div class="alert alert-info mt-2">
                Scanned: @CurrentFileIndex files
                @if (!string.IsNullOrEmpty(CurrentFileName))
                {
                    <div>Current: @CurrentFileName</div>
                }
            </div>
        }
    }
    else if (!DuplicateService.DuplicatesHandled)
    {
        <div class="alert alert-warning mt-2">
            ⚠ You must handle duplicates before continuing
            <button class="btn btn-sm btn-secondary ms-2" @onclick="GoToDuplicates">
                Go to Duplicates
            </button>
        </div>
    }
    else
    {
        <h4>File Summary</h4>

        <div class="main-category-row mt-3 d-flex gap-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = DuplicateService.AllFiles
                    .Where(f => f.MainCategory == cat)
                    .ToList();

                var count = filesInCat.Count(f => f.Status == MediaFileStatus.Initial || f.Status == MediaFileStatus.ToKeep);
                var size = filesInCat.Sum(f => f.SizeBytes);

                <div class="main-category-box p-3 text-center"
                     style="width:150px; border-radius:5px; cursor:@(IsCurrentCategory(cat) ? "pointer" : "not-allowed"); background:@GetCategoryColor(cat); opacity:@(IsCurrentCategory(cat) ? "1" : "0.6")"
                     @onclick="() => GoToCategory(cat)">
                    <strong>@cat</strong><br />
                    @count files<br />
                    @FormatSize(size)
                </div>
            }

            <div class="all-files-card p-3 text-center" style="width:150px; border:1px solid #ccc;">
                <strong>Total</strong><br />
                @DuplicateService.AllFiles.Count files<br />
                @FormatSize(DuplicateService.AllFiles.Sum(f => f.SizeBytes))
            </div>
        </div>
    }
</div>

@code {
    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    int CurrentFileIndex = 0;
    string CurrentFileName = "";

    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Audio,
        MediaMainCategory.Document,
        MediaMainCategory.Image,
        MediaMainCategory.Video
    };

    private MediaMainCategory CurrentStep
    {
        get
        {
            foreach (var cat in CategoryOrder)
            {
                if (DuplicateService.AllFiles.Any(f => f.MainCategory == cat && f.Status == MediaFileStatus.Initial))
                    return cat;
            }
            return CategoryOrder.Last();
        }
    }

    bool IsCurrentCategory(MediaMainCategory cat) => cat == CurrentStep;

    string GetCategoryColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "#28a745",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#ffc107",
        MediaMainCategory.Video => "#dc3545",
        _ => "#6c757d"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.#} {sizes[order]}";
    }

    void GoToCategory(MediaMainCategory cat)
    {
        if (!IsCurrentCategory(cat))
            return; // only current step is clickable

        var catStr = cat switch
        {
            MediaMainCategory.Audio => "audio",
            MediaMainCategory.Document => "document",
            MediaMainCategory.Image => "image",
            MediaMainCategory.Video => "video",
            _ => "audio"
        };

        Navigation.NavigateTo($"/category-step/{catStr}");
    }

    void GoToDuplicates() => Navigation.NavigateTo("/duplicates");

    async Task ScanFolder()
    {
        if (string.IsNullOrWhiteSpace(FolderPath) || !Directory.Exists(FolderPath))
            return;

        IsScanning = true;
        DuplicateService.AllFiles.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            var scanned = new List<MediaFile>();

            var files = FileScanner.ScanFolder(FolderPath, (i, path) =>
            {
                CurrentFileIndex = i;
                CurrentFileName = Path.GetFileName(path);
            }).ToList();

            foreach (var file in files)
            {
                file.WorkingPath = file.FullPath;
                file.Status = MediaFileStatus.Initial;

                // Hash
                try
                {
                    var hash = HashService.ComputeHash(file.FullPath);
                    file.SetHash(hash ?? $"{file.SizeBytes}_{file.FileName}");
                }
                catch
                {
                    file.SetHash($"{file.SizeBytes}_{file.FileName}");
                }

                // Categorize
                MediaCategorizer.Categorize(file);

                // Thumbnail
                var ext = Path.GetExtension(file.FullPath).ToLowerInvariant();
                file.ThumbnailPath = ext is ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".webp" or ".tiff" or ".tif"
                    ? $"/api/media?path={Uri.EscapeDataString(file.FullPath)}"
                    : "_content/file-icon.png";

                scanned.Add(file);
                await InvokeAsync(StateHasChanged); // update progress
            }

            DuplicateService.AllFiles = scanned;
            DuplicateService.DuplicatesHandled = false;
            DuplicateService.NotifyStateChanged();
        }
        finally
        {
            IsScanning = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}