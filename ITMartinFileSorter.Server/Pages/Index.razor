@page "/"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Application.UseCases
@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject ITMartinFileSorter.Domain.Interfaces.IHashService HashService
@inject NavigationManager Navigation

<div class="container mt-4">

    <!-- FOLDER INPUT -->
    <div class="folder-input d-flex mb-3">
        <input type="text" @bind="FolderPath" placeholder="Enter folder path..." class="form-control me-2" />
        <button class="btn btn-primary" @onclick="ScanFolder" disabled="@IsScanning">
            @(IsScanning ? "Scanning..." : "Scan")
        </button>
    </div>

    @if (IsScanning)
    {
        <div class="alert alert-info">Scanning files… please wait</div>
    }

    @if (DuplicateService.AllFiles.Any())
    {
        @if (DuplicateService.DuplicateGroups.Any(g => g.Count > 1) && !DuplicateService.DuplicatesHandled)
        {
            <div class="alert alert-warning">
                ⚠ You must handle duplicates before continuing
                <a class="btn btn-sm btn-secondary ms-2" @onclick="GoToDuplicates">Go to Duplicates</a>
            </div>
        }
        else
        {
            <h4>Step 2–5: File Categories</h4>

            @foreach (var cat in CategoryOrder)
            {
                @if (MainCategories.TryGetValue(cat, out var files) && files.Count > 0)
                {
                    <div class="category-box mb-3 p-3 text-center" 
                         style="background-color:@GetMainColor(cat); border-radius:5px; cursor:pointer;"
                         @onclick="() => GoToCategory(cat)">
                        <strong>@cat</strong><br />
                        @files.Count files
                    </div>
                }
            }
        }
    }
</div>

@code {
    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    Dictionary<MediaMainCategory, List<MediaFile>> MainCategories = new();
    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Document,
        MediaMainCategory.Audio,
        MediaMainCategory.Image,
        MediaMainCategory.Video
    };

    protected override void OnInitialized()
    {
        // If files exist (e.g., returned from duplicates), rebuild main categories
        if (DuplicateService.AllFiles.Any())
        {
            MainCategories = DuplicateService.AllFiles
                .Where(f => f.Keep)
                .GroupBy(f => f.MainCategory)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
    }

    async Task ScanFolder()
    {
        if (string.IsNullOrWhiteSpace(FolderPath) || !Directory.Exists(FolderPath))
            return;

        IsScanning = true;

        try
        {
            var scanned = await Task.Run(() => FileScanner.ScanFolder(FolderPath).ToList());

            // Compute hashes only for files with same size
            var groupedBySize = scanned.GroupBy(f => f.SizeBytes);
            await Task.Run(() =>
            {
                foreach (var group in groupedBySize)
                {
                    if (group.Count() == 1) continue;

                    foreach (var file in group)
                    {
                        try { file.SetHash(HashService.ComputeHash(file.FullPath)); }
                        catch { file.SetHash(null); }

                        // Set WorkingPath to original
                        file.WorkingPath = file.FullPath;
                    }
                }
            });

            // Find duplicates
            var finder = new DuplicateFinder();
            var duplicates = finder.FindDuplicates(scanned);

            DuplicateService.AllFiles = scanned;
            DuplicateService.DuplicateGroups = duplicates.Values.ToList();
            DuplicateService.DuplicatesHandled = false;

            // Prepare main categories
            MainCategories = DuplicateService.AllFiles
                .GroupBy(f => f.MainCategory)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        finally
        {
            IsScanning = false;
        }
    }

    void GoToDuplicates()
    {
        Navigation.NavigateTo("/duplicates");
    }

    void GoToCategory(MediaMainCategory cat)
    {
        Navigation.NavigateTo($"/category-step/{cat}");
    }

    string GetMainColor(MediaMainCategory main) => main switch
    {
        MediaMainCategory.Audio => "#6f42c1",
        MediaMainCategory.Video => "#dc3545",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#28a745",
        _ => "#6c757d"
    };
}