@page "/"
@page "/filesorter"

@using ITMartinFileSorter.Application.Services
@using ITMartin.Shared.UI.Components

@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject IHashService HashService
@inject MediaCategorizer MediaCategorizer
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject ThumbnailService ThumbnailService
@inject IConfiguration Configuration
@inject FolderPathInfoService FolderPathInfoService

<div class="index-page">

    <SectionTitle Title="🎬 ITMartins FileSorter" />

    <ContentCard>
        <p class="mb-0">
            Organize photos, videos, audio and documents.
            Scan a folder to begin sorting and duplicate detection.
        </p>

        <div class="mt-3">
            <button class="btn btn-primary"
                    @onclick="GoToLibrary">
                Open Library
            </button>
        </div>
    </ContentCard>

    <SectionTitle Title="Scan New Folder" />

    <FolderInputPanel
        Value="@FolderPath"
        ValueChanged="OnFolderPathChanged"
        ButtonText="@(IsScanning ? "Scanning..." : "Scan")"
        Disabled="@IsScanning"
        OnAction="ScanFolder" />

    @if (!string.IsNullOrWhiteSpace(PathInfo))
    {
        <ContentCard Title="Folder Info">
            @foreach (var line in PathInfo.Split('\n'))
            {
                <div>@line</div>
            }
        </ContentCard>
    }

    @if (ShowScanning)
    {
        <ProgressPanel
            Title="@Progress.Info.Stage"
            Current="@Progress.Info.WorkDone"
            Total="@Progress.Info.TotalWork"
            Percent="@ProgressPercent"
            CurrentItem="@CurrentFileName" />
    }

    @if (ShowDuplicateWarning)
    {
        <ContentCard Title="Attention">
            <EmptyState
                Message="⚠ You must handle duplicates before continuing"
                Type="warning" />

            <div class="mt-2">
                <button class="btn btn-sm btn-secondary"
                        @onclick="GoToDuplicates">
                    Go to Duplicates
                </button>
            </div>
        </ContentCard>
    }

    @if (ShowSummary)
    {
        <SectionTitle Title="File Summary" />

        <div class="main-category-row mt-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = DuplicateService.AllFiles
                    .Where(f => f.MainCategory == cat)
                    .ToList();

                var total = filesInCat.Count;
                var remaining = filesInCat.Count(f => f.Status == MediaFileStatus.Initial);
                var kept = filesInCat.Count(f => f.Status == MediaFileStatus.ToKeep);

                var isLocked = total == 0 || remaining == 0;

                <CategorySummaryCard
                    Title="@cat.ToString()"
                    Remaining="@remaining"
                    Kept="@kept"
                    Total="@total"
                    SizeText="@FormatSize(filesInCat.Sum(f => f.SizeBytes))"
                    CssClass="@GetCategoryCssClass(cat)"
                    IsLocked="@isLocked"
                    OnClick="@(() => OnCategoryClicked(cat, isLocked))" />
            }
        </div>
    }

    @if (AllCategoriesHandled)
    {
        <ContentCard Title="Export Ready">
            <div class="alert alert-success mb-3">
                ✔ Ready for export
            </div>

            <button class="btn btn-success"
                    @onclick="GoToExport">
                Export Organized Files
            </button>
        </ContentCard>
    }

</div>

@code {

    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    string CurrentFileName = "";
    int FilesDiscovered = 0;
    private string? PathInfo;

    int ProgressPercent => (int)Progress.Info.Percent;

    readonly MediaMainCategory[] CategoryOrder =
    {
        MediaMainCategory.Audio,
        MediaMainCategory.Document,
        MediaMainCategory.Image,
        MediaMainCategory.Video
    };

    bool ShowScanning => IsScanning;

    bool ShowDuplicateWarning =>
        !IsScanning &&
        DuplicateService.AllFiles.Any() &&
        !DuplicateService.DuplicatesHandled;

    bool ShowSummary =>
        !IsScanning &&
        DuplicateService.AllFiles.Any() &&
        DuplicateService.DuplicatesHandled;

    bool AllCategoriesHandled =>
        CategoryOrder.All(cat =>
            !DuplicateService.AllFiles
                .Any(f => f.MainCategory == cat &&
                          f.Status == MediaFileStatus.Initial));

    void GoToDuplicates() => Navigation.NavigateTo("/duplicates");
    void GoToExport() => Navigation.NavigateTo("/export");

    void GoToLibrary()
    {
        Navigation.NavigateTo("/library");
    }

    void GoToCategory(MediaMainCategory cat)
    {
        var hasRemaining = DuplicateService.AllFiles
            .Any(f => f.MainCategory == cat &&
                      f.Status == MediaFileStatus.Initial);

        if (!hasRemaining) return;

        Navigation.NavigateTo($"/category-step/{cat.ToString().ToLower()}");
    }

    void OnCategoryClicked(MediaMainCategory cat, bool isLocked)
    {
        if (!isLocked)
            GoToCategory(cat);
    }

    string GetCategoryCssClass(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "category-audio",
        MediaMainCategory.Document => "category-document",
        MediaMainCategory.Image => "category-image",
        MediaMainCategory.Video => "category-video",
        _ => ""
    };

    private void OnFolderPathChanged(string value)
    {
        FolderPath = value;
    }

    private void CheckSelectedFolder(string selectedFolder)
    {
        var defaultPath = Configuration["MediaSettings:LibraryRoot"];

        PathInfo = FolderPathInfoService.GetPathInfo(
            defaultPath,
            selectedFolder);

        StateHasChanged();
    }

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    async Task ScanFolder()
    {
        if (IsScanning) return;

        var path = FolderPath;

        if (string.IsNullOrWhiteSpace(path) ||
            !Directory.Exists(path))
            return;

        CheckSelectedFolder(path);

        IsScanning = true;
        FilesDiscovered = 0;

        DuplicateService.Reset();
        DuplicateService.FolderPath = path;

        await InvokeAsync(StateHasChanged);

        DuplicateService.Cancellation = new CancellationTokenSource();
        var token = DuplicateService.Cancellation.Token;

        try
        {
            Progress.SetStage("Scanning files...");
            Progress.Info.TotalWork = 0;

            var files = await Task.Run(() =>
            {
                var list = new List<MediaFile>();

                foreach (var file in FileScanner.ScanFolder(path))
                {
                    token.ThrowIfCancellationRequested();

                    list.Add(file);
                    FilesDiscovered++;
                }

                return list;
            }, token);

            DuplicateService.AllFiles = files;

            Progress.SetStage("Building duplicate groups...");
            DuplicateService.BuildDuplicateGroups();

            Progress.Complete();
        }
        catch (OperationCanceledException)
        {
            Progress.SetStage("Cancelled");
        }
        finally
        {
            IsScanning = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}