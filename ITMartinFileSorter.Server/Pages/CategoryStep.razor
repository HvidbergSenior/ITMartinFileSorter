@page "/category-step/{CategoryString}"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">
    <button class="btn btn-primary mb-3" @onclick="Continue" disabled="@(!CanContinue)">
        Continue
    </button>

    <h4>Step: @CurrentCategory</h4>

    @if (!FilesInCategory.Any())
    {
        <div class="alert alert-success">
            All files in this category handled.
        </div>
    }
    else
    {
        <button class="btn btn-success mb-3" @onclick="AcceptAll">
            Accept All
        </button>

        @if (CurrentCategory == MediaMainCategory.Audio)
        {
            <div class="d-flex gap-3 flex-wrap mb-3">
                @foreach (var group in AudioGroups)
                {
                    <div class="file-type-box p-2 border" style="width:150px;">
                        <strong>@group.Key</strong> (@(group.Value.Count()) files)
                        <div class="mt-2">
                            @foreach (var file in group.Value)
                            {
                                <div class="file-card mb-1" style="border:1px solid #ccc; padding:4px;">
                                    @file.FileName
                                    <button class="btn btn-sm btn-success ms-1" @onclick="() => Keep(file)">Keep</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (CurrentCategory == MediaMainCategory.Document)
        {
            <div class="d-flex gap-2 flex-wrap mb-3">
                @foreach (var file in FilesInCategory)
                {
                    <div class="file-card text-center p-2" style="width:150px; border:1px solid #ccc;">
                        @file.FileName
                        <button class="btn btn-sm btn-success mt-1" @onclick="() => Keep(file)">Keep</button>
                    </div>
                }
            </div>
        }
        else if (CurrentCategory == MediaMainCategory.Image || CurrentCategory == MediaMainCategory.Video)
        {
            @foreach (var yearGroup in YearGroups)
            {
                <h5>@yearGroup.Key</h5>
                @foreach (var monthGroup in yearGroup.Value)
                {
                    <div class="month-group mb-3 p-2 border">
                        <strong>@monthGroup.Key</strong> (@(monthGroup.Value.Count()) files)
                        <button class="btn btn-sm btn-success ms-2" @onclick="() => AcceptAll(monthGroup.Value)">Accept All Month</button>

                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @foreach (var file in monthGroup.Value)
                            {
                                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                                    @file.FileName
                                    <button class="btn btn-sm btn-success mt-1" @onclick="() => Keep(file)">Keep</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        }
    }
</div>

@code {
    [Parameter] public string CategoryString { get; set; } = "audio";

    private MediaMainCategory CurrentCategory;
    private List<MediaFile> FilesInCategory = new();
    private Dictionary<string, List<MediaFile>> AudioGroups = new();
    private Dictionary<int, Dictionary<int, List<MediaFile>>> YearGroups = new();

    bool CanContinue =>
        !DuplicateService.AllFiles
            .Any(f => f.MainCategory == CurrentCategory && f.Status == MediaFileStatus.Initial);

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString.ToLower() switch
        {
            "audio" => MediaMainCategory.Audio,
            "document" => MediaMainCategory.Document,
            "image" => MediaMainCategory.Image,
            "video" => MediaMainCategory.Video,
            _ => MediaMainCategory.Audio
        };

        LoadFiles();
    }

    void LoadFiles()
    {
        FilesInCategory = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory && f.Status == MediaFileStatus.Initial)
            .ToList();

        if (CurrentCategory == MediaMainCategory.Audio)
        {
            AudioGroups = FilesInCategory
                .GroupBy(f => f.Extension.ToLowerInvariant())
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else if (CurrentCategory == MediaMainCategory.Image || CurrentCategory == MediaMainCategory.Video)
        {
            YearGroups = FilesInCategory
                .GroupBy(f => f.Year)
                .OrderBy(g => g.Key)
                .ToDictionary(
                    g => g.Key,
                    g => g.GroupBy(f => f.Month)
                          .OrderBy(m => m.Key)
                          .ToDictionary(m => m.Key, m => m.ToList())
                );
        }
    }

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;
        LoadFiles();
    }

    void AcceptAll()
    {
        foreach (var file in FilesInCategory)
            file.Status = MediaFileStatus.ToKeep;

        LoadFiles();
    }

    void AcceptAll(List<MediaFile> files)
    {
        foreach (var file in files)
            file.Status = MediaFileStatus.ToKeep;

        LoadFiles();
    }

    void Continue()
    {
        Navigation.NavigateTo("/");
    }
}