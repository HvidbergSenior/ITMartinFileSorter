@page "/category-step/{CategoryString}"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">
    <a class="btn btn-secondary mb-3" href="/">← Back</a>
    <h4>Step: @CurrentCategory</h4>

    @{
        var remaining = DuplicateService.AllFiles
            .Count(f => f.MainCategory == CurrentCategory && f.Status == MediaFileStatus.Initial);

        Console.WriteLine($"[DEBUG] Remaining ({CurrentCategory}): {remaining}");
    }

    <div class="alert alert-info">
        Remaining: @remaining files
    </div>

    @if (SubGroups.Any())
    {
        <div class="d-flex gap-3 flex-wrap mb-3">
            @foreach (var key in SubGroups.Keys)
            {
                <div class="category-box text-center p-3"
                     style="cursor:pointer; background:#0d6efd; border-radius:5px; width:150px;"
                     @onclick="() => ToggleSubGroup(key)">

                    <strong>@key</strong><br />
                    @SubGroups[key].Count files

                    <div class="mt-2">
                        <button class="btn btn-sm btn-success me-1"
                                @onclick:stopPropagation
                                @onclick="() => KeepAll(key)">
                            Keep All
                        </button>

                        <button class="btn btn-sm btn-danger me-1"
                                @onclick:stopPropagation
                                @onclick="() => DeleteAll(key)">
                            Delete All
                        </button>

                        <button class="btn btn-sm btn-warning"
                                @onclick:stopPropagation
                                @onclick="() => DeleteAllButOne(key)">
                            Delete All But One
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @if (ExpandedSubKey != null && SubGroups.ContainsKey(ExpandedSubKey))
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            @foreach (var file in SubGroups[ExpandedSubKey])
            {
                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                    <div style="height:60px; display:flex; align-items:center; justify-content:center;">
                        @file.SubCategory
                    </div>

                    <div style="font-size:0.75em;">@file.FileName</div>

                    <button class="btn btn-sm btn-success mt-1 me-1"
                            @onclick="() => Keep(file)">
                        Keep
                    </button>

                    <button class="btn btn-sm btn-danger mt-1"
                            @onclick="() => Delete(file)">
                        Delete
                    </button>
                </div>
            }
        </div>
    }

    <button class="btn btn-primary"
            @onclick="GoNext"
            disabled="@(CanMoveNext == false)">
        Next →
    </button>

    @if (!CanMoveNext)
    {
        <div class="alert alert-warning mt-2">
            Handle all files before continuing.
        </div>
    }
</div>

@code {
    [Parameter] public string CategoryString { get; set; } = "image";

    private MediaMainCategory CurrentCategory;
    private Dictionary<string, List<MediaFile>> SubGroups = new();
    private string? ExpandedSubKey;

    bool CanMoveNext =>
        !DuplicateService.AllFiles
            .Any(f => f.MainCategory == CurrentCategory && f.Status == MediaFileStatus.Initial);

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString.ToLower() switch
        {
            "image" => MediaMainCategory.Image,
            "video" => MediaMainCategory.Video,
            "audio" => MediaMainCategory.Audio,
            "document" => MediaMainCategory.Document,
            _ => MediaMainCategory.Image
        };

        LoadSubGroups();

        Console.WriteLine($"[DEBUG] Initialized category: {CurrentCategory}");

        foreach (var f in DuplicateService.AllFiles.Where(f => f.MainCategory == CurrentCategory))
        {
            Console.WriteLine($"    {f.FileName} -> Status={f.Status}, Sub={f.SubCategory}");
        }
    }

    void LoadSubGroups()
    {
        var files = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory && f.Status == MediaFileStatus.Initial)
            .ToList();

        SubGroups = files
            .GroupBy(f => $"{f.SubCategory} - {f.Year}")
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

        Console.WriteLine($"[DEBUG] SubGroups created: {SubGroups.Count}");
        foreach (var g in SubGroups)
            Console.WriteLine($"    {g.Key}: {g.Value.Count} files");
    }

    void ToggleSubGroup(string key)
    {
        ExpandedSubKey = ExpandedSubKey == key ? null : key;
    }

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;
        Console.WriteLine($"[DEBUG] Keep: {file.FileName}");
        Refresh();
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;
        Console.WriteLine($"[DEBUG] Delete: {file.FileName}");
        Refresh();
    }

    void KeepAll(string key)
    {
        foreach (var f in SubGroups[key])
        {
            f.Status = MediaFileStatus.ToKeep;
            Console.WriteLine($"[DEBUG] KeepAll: {f.FileName}");
        }
        Refresh();
    }

    void DeleteAll(string key)
    {
        foreach (var f in SubGroups[key])
        {
            f.Status = MediaFileStatus.ToDelete;
            Console.WriteLine($"[DEBUG] DeleteAll: {f.FileName}");
        }
        Refresh();
    }

    void DeleteAllButOne(string key)
    {
        var list = SubGroups[key];
        if (!list.Any()) return;

        var newest = list.OrderByDescending(f => f.CreatedAt).First();

        foreach (var f in list)
        {
            f.Status = f == newest
                ? MediaFileStatus.ToKeep
                : MediaFileStatus.ToDelete;

            Console.WriteLine($"[DEBUG] DeleteAllButOne: {f.FileName} -> {f.Status}");
        }

        Refresh();
    }

    void Refresh()
    {
        LoadSubGroups();
        InvokeAsync(StateHasChanged);
    }

    void GoNext()
    {
        var order = new[]
        {
            MediaMainCategory.Image,
            MediaMainCategory.Video,
            MediaMainCategory.Audio,
            MediaMainCategory.Document
        };

        var index = Array.IndexOf(order, CurrentCategory);

        if (index < order.Length - 1)
        {
            var next = order[index + 1].ToString().ToLower();
            Navigation.NavigateTo($"/category-step/{next}");
        }
        else
        {
            Navigation.NavigateTo("/");
        }
    }
}