@page "/category-step/{CategoryString}"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject VideoThumbnailService VideoThumbnailService

<div class="container mt-4">
    <a class="btn btn-secondary mb-3" href="/">← Back to Home</a>

    <h4>Step: @CurrentCategory</h4>
    <div class="mb-2">
        Step @(Array.IndexOf(CategoryOrder, CurrentCategory) + 1) / @CategoryOrder.Length
    </div>

    @if (SubGroups.Any())
    {
        <div class="alert alert-info">
            Remaining: @SubGroups.Sum(g => g.Value.Count) files
        </div>

        <!-- SUBCATEGORY ROW -->
        <div class="sub-category-row mb-3">
            @foreach (var key in SubGroups.Keys)
            {
                <div class="sub-category-box @GetCategoryClass(CurrentCategory)"
                     @onclick="() => ToggleSubGroup(key)">
                    <strong>@key</strong><br />
                    @SubGroups[key].Count files<br />
                    @FormatSize(SubGroups[key].Sum(f => f.SizeBytes))
                    <div class="mt-2">
                        <button class="btn btn-sm btn-success me-1"
                                @onclick:stopPropagation
                                @onclick="() => KeepAll(key)">
                            Keep All
                        </button>
                        <button class="btn btn-sm btn-danger"
                                @onclick:stopPropagation
                                @onclick="() => DeleteAll(key)">
                            Delete All
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- FILES IN EXPANDED SUBCATEGORY -->
    @if (ExpandedSubKey != null && SubGroups.ContainsKey(ExpandedSubKey))
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            @foreach (var file in SubGroups[ExpandedSubKey])
            {
                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                    @if (file.MainCategory == MediaMainCategory.Image || file.MainCategory == MediaMainCategory.Video)
                    {
                        <img src="@file.ThumbnailPath"
                             style="width:100%; height:80px; object-fit:cover;" />
                    }
                    else
                    {
                        <div style="height:80px; display:flex; align-items:center; justify-content:center;">
                            @file.SubCategory
                        </div>
                    }
                    <div style="font-size:0.75em;">@Path.GetFileName(file.FullPath)</div>

                    <button class="btn btn-sm btn-success mt-1 me-1" @onclick="() => Keep(file)">Keep</button>
                    <button class="btn btn-sm btn-danger mt-1" @onclick="() => Delete(file)">Delete</button>
                </div>
            }
        </div>
    }

    <!-- NAVIGATION -->
    <div class="mt-3">
        <button class="btn btn-primary" @onclick="GoNext" disabled="@(CanMoveNext == false)">
            Next Category →
        </button>

        @if (!CanMoveNext && SubGroups.Any())
        {
            <div class="alert alert-warning mt-2">
                You must handle all files in this category before continuing.
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string CategoryString { get; set; } = "image";
    private MediaMainCategory CurrentCategory { get; set; }
    Dictionary<string, List<MediaFile>> SubGroups = new();
    string? ExpandedSubKey;

    bool CanMoveNext => !DuplicateService.AllFiles
            .Any(f => f.MainCategory == CurrentCategory && !f.Keep);

    private readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString?.ToLowerInvariant() switch
        {
            "image" or "images" => MediaMainCategory.Image,
            "video" or "videos" => MediaMainCategory.Video,
            "audio" or "audios" => MediaMainCategory.Audio,
            "document" or "documents" => MediaMainCategory.Document,
            _ => MediaMainCategory.Image
        };

        LoadSubGroups();

        // Auto skip empty category
        if (!SubGroups.Any())
        {
            DuplicateService.CompletedCategories.Add(CurrentCategory);
            GoNext();
        }
    }

    void LoadSubGroups()
    {
        var files = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory && !f.Keep)
            .ToList();

        if (CurrentCategory == MediaMainCategory.Image || CurrentCategory == MediaMainCategory.Video)
        {
            SubGroups = files
                .GroupBy(f => $"{f.Year}-{f.Month:D2}")
                .OrderByDescending(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else
        {
            SubGroups = files
                .GroupBy(f => $"{f.SubCategory} - {f.Year}")
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
    }

    void ToggleSubGroup(string key) => ExpandedSubKey = ExpandedSubKey == key ? null : key;

    void Keep(MediaFile file)
    {
        file.Keep = true;
        LoadSubGroups();
    }

    void Delete(MediaFile file)
    {
        file.Keep = false;
        LoadSubGroups();
    }

    void KeepAll(string key)
    {
        foreach (var f in SubGroups[key])
            f.Keep = true;

        LoadSubGroups();
    }

    void DeleteAll(string key)
    {
        foreach (var f in SubGroups[key])
            f.Keep = false;

        LoadSubGroups();
    }

    bool _navigating = false;
    void GoNext()
    {
        if (_navigating) return;
        _navigating = true;

        DuplicateService.CompletedCategories.Add(CurrentCategory);
        var index = Array.IndexOf(CategoryOrder, CurrentCategory);

        if (index < CategoryOrder.Length - 1)
            Navigation.NavigateTo($"/category-step/{CategoryOrder[index + 1]}");
        else
            Navigation.NavigateTo("/");
    }

    string GetCategoryClass(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Image => "category-image",
        MediaMainCategory.Video => "category-video",
        MediaMainCategory.Audio => "category-audio",
        MediaMainCategory.Document => "category-document",
        _ => ""
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.#} {sizes[order]}";
    }
}