@page "/category-step/{CategoryString}"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@using ITMartinFileSorter.Domain.Entities
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">

    <!-- TOP BAR -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <button class="btn btn-primary"
                @onclick="Continue"
                disabled="@(!CanContinue)">
            Continue
        </button>

        <button class="btn btn-success"
                @onclick="AcceptAll"
                disabled="@(!FilesInCategory.Any())">
            Accept All
        </button>
    </div>

    <h4>Step: @CurrentCategory</h4>

    @if (!FilesInCategory.Any())
    {
        <div class="alert alert-success">
            All files in this category handled.
        </div>
    }
    else if (CurrentCategory == MediaMainCategory.Audio)
    {
        <div class="d-flex gap-3 flex-wrap mb-3">

            @foreach (var group in AudioGroups)
            {
                <div class="p-2 border rounded">
                    <strong>@group.Key</strong> (@group.Value.Count files)

                    <div class="d-flex gap-2 flex-wrap mt-2">
                        @foreach (var file in group.Value)
                        {
                            <MediaCard File="file" OnKeep="Keep" />
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (CurrentCategory == MediaMainCategory.Document)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">

            @foreach (var file in FilesInCategory)
            {
                <MediaCard File="file" OnKeep="Keep" />
            }

        </div>
    }
    else if (CurrentCategory == MediaMainCategory.Image ||
             CurrentCategory == MediaMainCategory.Video)
    {
        @foreach (var yearGroup in YearGroups)
        {
            <div class="mb-4 p-2 border rounded">

                <div class="d-flex justify-content-between align-items-center">
                    <h5>@yearGroup.Key</h5>

                    <button class="btn btn-sm btn-success"
                            @onclick="() => AcceptAll(yearGroup.Value)">
                        Accept All Year
                    </button>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-2">

                    @foreach (var file in yearGroup.Value)
                    {
                        <MediaCard File="file" OnKeep="Keep" />
                    }

                </div>
            </div>
        }
    }

</div>

@code {

    [Parameter] public string CategoryString { get; set; } = "audio";

    private MediaMainCategory CurrentCategory;
    private List<MediaFile> FilesInCategory = new();
    private Dictionary<string, List<MediaFile>> AudioGroups = new();
    private Dictionary<int, List<MediaFile>> YearGroups = new();
    bool CanContinue =>
        !DuplicateService.AllFiles
            .Any(f => f.MainCategory == CurrentCategory &&
                      f.Status == MediaFileStatus.Initial);

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString.ToLower() switch
        {
            "audio" => MediaMainCategory.Audio,
            "document" => MediaMainCategory.Document,
            "image" => MediaMainCategory.Image,
            "video" => MediaMainCategory.Video,
            _ => MediaMainCategory.Audio
        };

        LoadFiles();
    }

    void LoadFiles()
    {
        FilesInCategory = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory &&
                        f.Status == MediaFileStatus.Initial)
            .ToList();

        if (CurrentCategory == MediaMainCategory.Audio)
        {
            AudioGroups = FilesInCategory
                .GroupBy(f => f.Extension.ToLowerInvariant())
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else if (CurrentCategory == MediaMainCategory.Image ||
                 CurrentCategory == MediaMainCategory.Video)
        {
            YearGroups = FilesInCategory
                .GroupBy(f => f.Year)
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
    }

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;
        LoadFiles();
    }

    void AcceptAll()
    {
        foreach (var file in FilesInCategory)
            file.Status = MediaFileStatus.ToKeep;

        LoadFiles();
    }

    void AcceptAll(List<MediaFile> files)
    {
        foreach (var file in files)
            file.Status = MediaFileStatus.ToKeep;

        LoadFiles();
    }

    void Continue()
    {
        Navigation.NavigateTo("/");
    }
}