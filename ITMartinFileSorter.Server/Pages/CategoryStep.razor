@page "/category-step/{CategoryString}"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject VideoThumbnailService VideoThumbnailService

<div class="container mt-4">
    <a class="btn btn-secondary mb-3" href="/">← Back to Home</a>
    <h4>Step: @CurrentCategory</h4>

    @if (SubGroups.Any())
    {
        <div class="d-flex gap-3 flex-wrap mb-3">
            @foreach (var key in SubGroups.Keys)
            {
                <div class="category-box text-center p-3"
                     style="cursor:pointer; background-color:@GetColor(CurrentCategory); border-radius:5px; width:150px;"
                     @onclick="() => ToggleSubGroup(key)">
                    <strong>@key</strong><br />
                    @SubGroups[key].Count files
                </div>
            }
        </div>
    }

    @if (ExpandedSubKey != null && SubGroups.ContainsKey(ExpandedSubKey))
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            @foreach (var file in SubGroups[ExpandedSubKey])
            {
                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                    <img src="@file.ThumbnailPath"
                         alt="@file.FileName"
                         style="width:100%; height:80px; object-fit:cover;" />
                    <div style="font-size:0.75em;">@Path.GetFileName(file.FullPath)</div>

                    <button class="btn btn-sm btn-success mt-1 me-1" @onclick="() => Keep(file)">Keep</button>
                    <button class="btn btn-sm btn-danger mt-1" @onclick="() => Delete(file)">Delete</button>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="GoNext" disabled="@(CanMoveNext == false)">
            Next Category →
        </button>

        @if (CurrentCategory == CategoryOrder.Last())
        {
            <button class="btn btn-success ms-2" @onclick="ExportStructured">
                Finish & Export
            </button>
        }

        @if (!CanMoveNext && SubGroups.Any())
        {
            <div class="alert alert-warning mt-2">
                You must handle all files in this category before continuing.
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string CategoryString { get; set; } = "image";

    private MediaMainCategory CurrentCategory { get; set; }
    Dictionary<string, List<MediaFile>> SubGroups = new();
    string? ExpandedSubKey;

    bool CanMoveNext => !SubGroups.Any() || SubGroups.All(g => g.Value.Count == 0);

    private readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString?.ToLowerInvariant() switch
        {
            "image" or "images" => MediaMainCategory.Image,
            "video" or "videos" => MediaMainCategory.Video,
            "audio" or "audios" => MediaMainCategory.Audio,
            "document" or "documents" => MediaMainCategory.Document,
            _ => MediaMainCategory.Image
        };

        LoadSubGroups();
    }

    void LoadSubGroups()
    {
        var files = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory)
            .ToList();

        if (CurrentCategory == MediaMainCategory.Image || CurrentCategory == MediaMainCategory.Video)
        {
            SubGroups = files
                .GroupBy(f => f.Year.ToString())
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else
        {
            SubGroups = files
                .GroupBy(f => Path.GetExtension(f.FileName).ToLower())
                .ToDictionary(g => g.Key, g => g.ToList());
        }
    }

    void ToggleSubGroup(string key)
    {
        ExpandedSubKey = ExpandedSubKey == key ? null : key;
    }

    void Keep(MediaFile file)
    {
        file.Keep = true;
        if (ExpandedSubKey != null)
            SubGroups[ExpandedSubKey].Remove(file);
    }

    void Delete(MediaFile file)
    {
        file.Keep = false;
        if (ExpandedSubKey != null)
            SubGroups[ExpandedSubKey].Remove(file);
    }

    void GoNext()
    {
        var index = Array.IndexOf(CategoryOrder, CurrentCategory);
        if (index < CategoryOrder.Length - 1)
        {
            var next = CategoryOrder[index + 1];
            Navigation.NavigateTo($"/category-step/{next}");
        }
        else
        {
            ExportStructured();
            Navigation.NavigateTo("/");
        }
    }

    void ExportStructured()
    {
        var root = Path.Combine(DuplicateService.FolderPath, "Structured");

        foreach (var cat in CategoryOrder)
            Directory.CreateDirectory(Path.Combine(root, cat + "s"));

        foreach (var file in DuplicateService.AllFiles.Where(f => f.Keep))
        {
            string folder = file.MainCategory + "s";
            string destFolder = Path.Combine(root, folder);

            string dest = Path.Combine(destFolder, file.FileName);
            int count = 1;

            while (File.Exists(dest))
            {
                var name = Path.GetFileNameWithoutExtension(file.FileName);
                var ext = Path.GetExtension(file.FileName);
                dest = Path.Combine(destFolder, $"{name}_{count}{ext}");
                count++;
            }

            File.Copy(file.FullPath, dest);
        }
    }

    string GetColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Video => "#dc3545",
        MediaMainCategory.Image => "#28a745",
        MediaMainCategory.Audio => "#ffc107",
        MediaMainCategory.Document => "#0d6efd",
        _ => "#6c757d"
    };

    string GetThumbnail(string? path)
    {
        if (string.IsNullOrEmpty(path) || !File.Exists(path))
            return "_content/placeholder.png";

        var ext = Path.GetExtension(path).ToLowerInvariant();

        if (ext is ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".webp" or ".tiff" or ".tif")
            return $"/api/media?path={Uri.EscapeDataString(path)}";

        if (ext is ".mp4" or ".mov" or ".avi" or ".wmv" or ".mkv")
        {
            try
            {
                var thumbFileName = VideoThumbnailService.GenerateThumbnail(path);
                return $"/media_temp/{thumbFileName}";
            }
            catch
            {
                return "_content/video-icon.png";
            }
        }

        if (ext is ".mp3" or ".wav" or ".aac")
            return "_content/audio-icon.png";

        if (ext is ".pdf" or ".doc" or ".docx" or ".xls" or ".xlsx" or ".txt")
            return "_content/file-icon.png";

        return "_content/file-icon.png";
    }
}