@page "/export"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject VideoConverterService VideoConverterService
@inject MediaServerProService MediaServerProService
<div class="container mt-4">

    <h4>Export Organized Files</h4>

    @if (!FilesToExport.Any())
    {
        <div class="alert alert-warning">
            No files marked to keep.
        </div>
    }
    else
    {
        <h5>Preview of new structure</h5>

        <div class="border p-3 mb-3" style="max-height:400px; overflow:auto;">
            @foreach (var folder in ExportStructure)
            {
                <div class="mb-2">
                    <strong>@folder.Key</strong>
                    <ul>
                        @foreach (var file in folder.Value)
                        {
                            <li>@file.FileName</li>
                        }
                    </ul>
                </div>
            }
        </div>

        <button class="btn btn-success" @onclick="ExportFiles">
            Create "after" Folder
        </button>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert alert-info mt-3">@Message</div>
        }
    }
    @if (!string.IsNullOrEmpty(ExportPath) &&
         Directory.Exists(Path.Combine(ExportPath, "Videos")))
    {
        <button class="btn btn-warning mt-3"
                disabled="@IsConverting"
                @onclick="ConvertVideos">
            Optional: Convert Videos for Synology
        </button>
    }
    
    @if (IsConverting || !string.IsNullOrEmpty(ConversionStatus))
    {
        <div class="alert alert-info mt-3">
            @ConversionStatus
        </div>
    }
</div>

@code {
    bool IsConverting = false;
    string ConversionStatus = "";
    string ExportPath = "";

    IEnumerable<MediaFile> FilesToExport =>
        DuplicateService.AllFiles
            .Where(f => f.Status == MediaFileStatus.ToKeep);

    Dictionary<string, List<MediaFile>> ExportStructure =>
        FilesToExport
            .GroupBy(f => f.DynamicFolder ?? "Other")
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

    string Message = "";

    async Task ExportFiles()
    {
        try
        {
            var sourceRoot = DuplicateService.FolderPath;

            if (string.IsNullOrWhiteSpace(sourceRoot) ||
                !Directory.Exists(sourceRoot))
            {
                Message = "Invalid source folder.";
                return;
            }

            var targetRoot = Path.Combine(sourceRoot, "After");
            Directory.CreateDirectory(targetRoot);

            int copied = 0;

            var options = DuplicateService.GroupingOptions ?? new GroupingOptions();

            foreach (var file in FilesToExport)
            {
                var subFolder = file.DynamicFolder ?? "Other";

                var destFolder = Path.Combine(targetRoot, subFolder);
                Directory.CreateDirectory(destFolder);

                var sourcePath = file.WorkingPath ?? file.FullPath;

                // ⭐ Album-style name
                var newName = AlbumStyleNameBuilder.Build(
                    file,
                    copied + 1);

                // ⭐ Prevent collisions
                newName = AlbumStyleNameBuilder.EnsureUnique(
                    destFolder,
                    newName);

                var destPath = Path.Combine(destFolder, newName);

                try
                {
                    File.Copy(sourcePath, destPath, overwrite: false);
                    copied++;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Copy failed: {file.FileName} — {ex.Message}");
                }
            }

            ExportPath = targetRoot;

            Message = $"Export completed. {copied} files copied to:\n{targetRoot}";
        }
        catch (Exception ex)
        {
            Message = $"Export failed: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    async Task ConvertVideos()
    {
        if (string.IsNullOrWhiteSpace(ExportPath))
        {
            ConversionStatus = "Export first.";
            return;
        }

        IsConverting = true;
        ConversionStatus = "Running Media Server optimization...";

        await MediaServerProService.OptimizeExportAsync(
            ExportPath,
            progress =>
            {
                ConversionStatus = progress;
                InvokeAsync(StateHasChanged);
            });

        ConversionStatus = "DONE ✅ Media Server Ready!";
        IsConverting = false;
    }
}