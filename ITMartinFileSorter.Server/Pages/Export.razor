@page "/export"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject FastVideoBatchExportService FastVideoBatchExportService
<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Export Organized Files</h4>

        <button class="btn btn-outline-secondary"
                @onclick="GoBack">
            Back
        </button>
    </div>

    <!-- DESTINATION -->
    <div class="card mb-3">
        <div class="card-header bg-light">
            Destination
        </div>

        <div class="card-body">
            <div class="text-muted">
                Files will be organized into category and year folders
                inside an <strong>Exported</strong> folder.
            </div>
        </div>
    </div>

    <!-- STRUCTURE PREVIEW -->
    <div class="card mb-3">

        <div class="card-header bg-light">
            <strong>Export Structure Preview</strong>
        </div>

        <div class="card-body">

            @foreach (var cat in CategoryOrder)
            {
                var kept = DuplicateService.AllFiles
                    .Where(f => f.MainCategory == cat &&
                                f.Status == MediaFileStatus.ToKeep)
                    .ToList();

                if (!kept.Any()) continue;

                <div class="mb-4">

                    <div style="font-weight:600; color:@GetCategoryColor(cat)">
                        @GetCategoryIcon(cat) @cat (@kept.Count files)
                    </div>

                    @foreach (var yearGroup in kept
                        .GroupBy(f => f.Year)
                        .OrderByDescending(g => g.Key))
                    {
                        <div class="ms-3">
                            📂 @yearGroup.Key (@yearGroup.Count())
                        </div>
                    }

                </div>
            }

        </div>
    </div>

    <!-- PROGRESS -->
    @if (IsExporting)
    {
        <div class="alert alert-info">
            <strong>Exporting files...</strong>

            <div class="progress mt-2">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width:@ProgressPercent%">
                    @ExportedCount / @TotalToExport
                </div>
            </div>

            <div class="mt-1">@CurrentExportFile</div>
        </div>
    }

    <!-- ACTION BUTTON (LEFT) -->
    <div>
        <button class="btn btn-success btn-lg"
                @onclick="StartExport"
                disabled="@IsExporting">
            Start Export
        </button>
    </div>

</div>

@code {

    bool IsExporting = false;
    int ExportedCount = 0;
    int TotalToExport = 0;
    string CurrentExportFile = "";

    int ProgressPercent =>
        TotalToExport == 0 ? 0 :
        (int)((double)ExportedCount / TotalToExport * 100);

    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    string GetCategoryColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "#28a745",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#ffc107",
        MediaMainCategory.Video => "#dc3545",
        _ => "#6c757d"
    };

    string GetCategoryIcon(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Image => "🖼️",
        MediaMainCategory.Video => "🎬",
        MediaMainCategory.Audio => "🎵",
        MediaMainCategory.Document => "📄",
        _ => "📁"
    };

    void GoBack() => Navigation.NavigateTo("/");

    async Task StartExport()
{
    Console.WriteLine("[EXPORT] StartExport called");

    var files = DuplicateService.AllFiles
        .Where(f => f.Status == MediaFileStatus.ToKeep)
        .ToList();

    if (!files.Any())
        return;

    var exportRoot = Path.Combine(
        DuplicateService.FolderPath,
        "Exported");

    Directory.CreateDirectory(exportRoot);

    IsExporting = true;
    ExportedCount = 0;
    TotalToExport = 0;

    await InvokeAsync(StateHasChanged);

    try
    {
        // ===== COPY PHASE =====
        CurrentExportFile = "Copying files...";
        Console.WriteLine("[EXPORT] Starting copy phase");

        foreach (var file in files)
        {
            var categoryFolder = Path.Combine(
                exportRoot,
                file.MainCategory.ToString());

            var yearFolder = Path.Combine(
                categoryFolder,
                file.Year.ToString());

            Directory.CreateDirectory(yearFolder);

            var destination = Path.Combine(
                yearFolder,
                file.FileName);

            File.Copy(file.WorkingPath, destination, true);
        }

        Console.WriteLine("[EXPORT] Copy phase DONE");

        // ===== CONVERSION PHASE =====
        CurrentExportFile = "Converting videos...";
        ExportedCount = 0;
        TotalToExport = 0;

        await InvokeAsync(StateHasChanged);

        Console.WriteLine("[EXPORT] Starting video conversion phase");

        await FastVideoBatchExportService.ConvertAllVideosAsync(
            exportRoot,
            (current, total, name) =>
            {
                ExportedCount = current;
                TotalToExport = total;
                CurrentExportFile = "Converting: " + name;

                InvokeAsync(StateHasChanged);
            });

        Console.WriteLine("[EXPORT] Conversion phase DONE");

        CurrentExportFile = "Export complete ✔";
    }
    catch (Exception ex)
    {
        Console.WriteLine("[EXPORT ERROR] " + ex);
        CurrentExportFile = "ERROR: " + ex.Message;
    }
    finally
    {
        IsExporting = false;
        await InvokeAsync(StateHasChanged);

        Console.WriteLine("[EXPORT] Finished (finally)");
    }
}
}
