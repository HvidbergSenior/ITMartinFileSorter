@page "/export"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject FastVideoBatchExportService FastVideoBatchExportService

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Export Organized Files</h4>

        <button class="btn btn-outline-secondary"
                @onclick="GoBack">
            Back
        </button>
    </div>

    <!-- DESTINATION -->
    <div class="card mb-3">
        <div class="card-header bg-light">Destination</div>
        <div class="card-body">
            Files will be organized into category + year folders
            inside an <strong>Exported</strong> folder.
        </div>
    </div>

    <!-- STRUCTURE PREVIEW -->
    <div class="card mb-3">
        <div class="card-header bg-light">
            <strong>Export Structure Preview</strong>
        </div>

        <div class="card-body">

            @foreach (var cat in CategoryOrder)
            {
                var kept = DuplicateService.AllFiles
                    .Where(f => f.MainCategory == cat &&
                                f.Status == MediaFileStatus.ToKeep)
                    .ToList();

                if (!kept.Any()) continue;

                <div class="mb-3">

                    <div style="font-weight:600; color:@GetCategoryColor(cat)">
                        @GetCategoryIcon(cat) @cat (@kept.Count files)
                    </div>

                    @foreach (var yearGroup in kept
                        .GroupBy(f => f.Year)
                        .OrderByDescending(g => g.Key))
                    {
                        <div class="ms-3">
                            📂 @yearGroup.Key (@yearGroup.Count())
                        </div>
                    }

                </div>
            }

        </div>
    </div>

    <!-- PROGRESS -->
    @if (IsExporting)
    {
        <div class="alert alert-info">

            <strong>@CurrentStage</strong>

            <div class="progress mt-2">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width:@ProgressPercent%">
                    @ExportedCount / @TotalToExport
                </div>
            </div>

            <div class="mt-2">@CurrentExportFile</div>
        </div>
    }

    <!-- ACTION -->
    <button class="btn btn-success btn-lg"
            @onclick="StartExport"
            disabled="@IsExporting">
        Start Export
    </button>

</div>

@code {

    bool IsExporting = false;
    int ExportedCount = 0;
    int TotalToExport = 0;

    string CurrentExportFile = "";
    string CurrentStage = "";

    int ProgressPercent =>
        TotalToExport == 0 ? 0 : (int)((double)ExportedCount / TotalToExport * 100);

    readonly MediaMainCategory[] CategoryOrder =
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    string GetCategoryColor(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Audio => "#28a745",
        MediaMainCategory.Document => "#0d6efd",
        MediaMainCategory.Image => "#ffc107",
        MediaMainCategory.Video => "#dc3545",
        _ => "#6c757d"
    };

    string GetCategoryIcon(MediaMainCategory cat) => cat switch
    {
        MediaMainCategory.Image => "🖼️",
        MediaMainCategory.Video => "🎬",
        MediaMainCategory.Audio => "🎵",
        MediaMainCategory.Document => "📄",
        _ => "📁"
    };

    void GoBack() => Navigation.NavigateTo("/");

    async Task StartExport()
{
    var files = DuplicateService.AllFiles
        .Where(f => f.Status == MediaFileStatus.ToKeep)
        .ToList();

    if (!files.Any())
        return;

    var exportRoot = Path.Combine(
        DuplicateService.FolderPath,
        "Exported");

    Directory.CreateDirectory(exportRoot);

    IsExporting = true;
    ExportedCount = 0;
    TotalToExport = files.Count;
    CurrentStage = "Copying files...";

    await InvokeAsync(StateHasChanged);

    try
    {
        var archiveOptions = new ArchiveOptions
        {
            UseYearFolders = true,
            UseMonthFolders = true,
            UseTypeFolders = false,
            UseTripFolders = true,
            RenameFiles = true,
            RenameStrategy = RenameStrategy.AlbumStyle
        };

        // 🔥 Build structure once
        var builder = new ArchivePathBuilder(
            new TripGroupingService());

        var pathMap = builder.BuildStructure(
            files,
            archiveOptions);

        // 🔥 DEBUG: show complete path map
        Console.WriteLine("===== EXPORT PATH MAP DEBUG =====");

        foreach (var kvp in pathMap)
        {
            Console.WriteLine($"PATH: {kvp.Key}");

            foreach (var mappedFile in kvp.Value)
            {
                Console.WriteLine($"   -> {mappedFile.FileName} [{mappedFile.SubCategory}]");
            }
        }

        // 🔥 safer lookup
        var filePathLookup = new Dictionary<MediaFile, string>();

        foreach (var kvp in pathMap)
        {
            foreach (var mappedFile in kvp.Value)
            {
                filePathLookup[mappedFile] = kvp.Key;
            }
        }

        foreach (var file in files)
        {
            CurrentExportFile = file.FileName;

            var relativePath = filePathLookup[file];

            // 🔥 DEBUG
            Console.WriteLine(
                $"EXPORT FILE: {file.FileName} -> {relativePath}");

            var targetFolder = Path.Combine(
                exportRoot,
                relativePath);

            Directory.CreateDirectory(targetFolder);

            var newName = archiveOptions.RenameFiles
                ? FileRenameService.BuildName(
                    file,
                    ExportedCount + 1,
                    archiveOptions.RenameStrategy)
                : file.FileName;

            newName = AlbumStyleNameBuilder.EnsureUnique(
                targetFolder,
                newName);

            var destination = Path.Combine(
                targetFolder,
                newName);

            Console.WriteLine(
                $"COPY TO: {destination}");

            using var source = new FileStream(
                file.WorkingPath,
                FileMode.Open,
                FileAccess.Read,
                FileShare.Read,
                81920,
                true);

            using var dest = new FileStream(
                destination,
                FileMode.Create,
                FileAccess.Write,
                FileShare.None,
                81920,
                true);

            await source.CopyToAsync(dest);

            var created = File.GetCreationTime(file.WorkingPath);
            var modified = File.GetLastWriteTime(file.WorkingPath);

            if (created.Year < 2000)
                created = modified;

            File.SetCreationTime(destination, created);
            File.SetLastWriteTime(destination, modified);

            ExportedCount++;

            if (ExportedCount % 10 == 0)
                await InvokeAsync(StateHasChanged);
        }

        CurrentStage = "Export complete ✔";
        CurrentExportFile = "";
    }
    catch (Exception ex)
    {
        CurrentStage = "ERROR";
        CurrentExportFile = ex.ToString();

        Console.WriteLine("===== EXPORT ERROR =====");
        Console.WriteLine(ex);
    }
    finally
    {
        IsExporting = false;
        await InvokeAsync(StateHasChanged);
    }
}
}