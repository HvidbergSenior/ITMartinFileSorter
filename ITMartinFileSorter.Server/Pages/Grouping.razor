@page "/grouping"
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">

    <h3>Choose Organization Method</h3>

    <select class="form-select mb-3" @bind="Options.Strategy">
        @foreach (GroupingStrategy s in Enum.GetValues<GroupingStrategy>())
        {
            <option value="@s">@s</option>
        }
    </select>

    @if (Options.Strategy == GroupingStrategy.CustomPrefix)
    {
        <input class="form-control mb-3"
               placeholder="Enter prefix (e.g., Thailand)"
               @bind="Options.CustomPrefix" />
    }

    <div class="form-check">
        <input type="checkbox" class="form-check-input"
               @bind="Options.CreateSubfolders" />
        <label>Create subfolders</label>
    </div>

    <div class="form-check mb-3">
        <input type="checkbox" class="form-check-input"
               @bind="Options.RenameFiles" />
        <label>Rename files</label>
    </div>

    <button class="btn btn-success" @onclick="Continue">
        Continue to Export
    </button>

</div>

@code {

    GroupingOptions Options = new();

    void Continue()
    {
        DuplicateService.GroupingOptions = Options;
        Navigation.NavigateTo("/export");
    }
}