@page "/images"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<h3>Images</h3>

@if (!ImageFiles.Any())
{
    <div class="alert alert-info">No image files found.</div>
    <button class="btn btn-primary" @onclick="GoNext">Next Step</button>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-3">
        @foreach (var group in SubGroups.Keys)
        {
            <div class="all-files-card p-3 text-center" style="width:200px; cursor:pointer"
                 @onclick="() => ToggleSubGroup(group)">
                <strong>@group</strong><br />@SubGroups[group].Count files
            </div>
        }
    </div>

    @if (ExpandedSubKey != null)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            @foreach (var file in SubGroups[ExpandedSubKey])
            {
                <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                    <img src="@GetThumbnail(file.WorkingPath)" style="width:100%; height:80px; object-fit:cover;" />
                    <div style="font-size:0.75em;">@file.FileName</div>
                </div>
            }
        </div>
    }

    <button class="btn btn-success mt-3" @onclick="Accept">Accept & Continue</button>
}

@code {
    List<MediaFile> ImageFiles => DuplicateService.AllFiles
        .Where(f => f.MainCategory == MediaMainCategory.Image)
        .ToList();

    Dictionary<string, List<MediaFile>> SubGroups = new();
    string? ExpandedSubKey;

    protected override void OnInitialized()
    {
        // Group by Year-Month
        SubGroups = ImageFiles
            .GroupBy(f => $"{f.Year}-{f.Month:D2}")
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void ToggleSubGroup(string key) => ExpandedSubKey = ExpandedSubKey == key ? null : key;

    void Accept()
    {
        foreach (var file in ImageFiles) file.Keep = true;
        GoNext();
    }

    void GoNext()
    {
        Navigation.NavigateTo(DuplicateService.AllFiles.Any(f => f.MainCategory == MediaMainCategory.Video)
            ? "/videos"
            : "/");
    }

    string GetThumbnail(string? path)
    {
        if (string.IsNullOrEmpty(path) || !File.Exists(path)) return "_content/placeholder.png";
        var ext = Path.GetExtension(path).ToLowerInvariant();
        if (ext is ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".webp" or ".tiff" or ".tif") return $"/api/media?path={Uri.EscapeDataString(path)}";
        return "_content/file-icon.png";
    }
}