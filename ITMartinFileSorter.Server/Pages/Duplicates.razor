@page "/duplicates"
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">

    <h4>Handle Duplicates</h4>

    <div class="d-flex justify-content-between mb-3">

        <button class="btn btn-success"
                @onclick="Continue"
                disabled="@(!AllGroupsHandled)">
            Continue
        </button>

        <button class="btn btn-danger"
                @onclick="DeleteAllDuplicatesGlobally">
            Delete All (Keep Newest)
        </button>
    </div>

    @if (!DuplicateService.DuplicateGroups.Any())
    {
        <div class="alert alert-success">
            No duplicates found
        </div>
    }
    else
    {
        @foreach (var group in DuplicateService.CurrentPageGroups)
        {
            <div class="border p-2 mb-3">

                <div class="d-flex gap-2 flex-wrap">

                    @foreach (var file in group)
                    {
                        <div style="width:140px"
                             class="border p-2 text-center">

                            <div style="font-size:0.75em">
                                @file.FileName
                            </div>

                            <div style="font-size:0.7em">
                                @FormatSize(file.SizeBytes)
                            </div>

                            @if (file.Status == MediaFileStatus.Initial)
                            {
                                <button class="btn btn-sm btn-success w-100"
                                        @onclick="() => Keep(file)">
                                    Keep
                                </button>

                                <button class="btn btn-sm btn-danger w-100"
                                        @onclick="() => Delete(file)">
                                    Delete
                                </button>
                            }
                            else
                            {
                                <div>@file.Status</div>
                            }
                        </div>
                    }

                </div>

                <button class="btn btn-sm btn-danger mt-2"
                        @onclick="() => DeleteAllButOne(group)">
                    Delete All But One
                </button>
            </div>
        }

        <!-- PAGINATION -->
        <div class="d-flex justify-content-center gap-2 mt-3">

            <button class="btn btn-secondary"
                    disabled="@(DuplicateService.CurrentPage == 0)"
                    @onclick="PrevPage">
                Previous
            </button>

            <span>
                Page @(DuplicateService.CurrentPage + 1)
                of @DuplicateService.TotalPages
            </span>

            <button class="btn btn-secondary"
                    disabled="@(DuplicateService.CurrentPage >= DuplicateService.TotalPages - 1)"
                    @onclick="NextPage">
                Next
            </button>
        </div>
    }

</div>

@code {

    bool AllGroupsHandled =>
        DuplicateService.DuplicateGroups
            .All(g => g.Count(f => f.Status == MediaFileStatus.ToDelete) == g.Count - 1);

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;
    }

    void DeleteAllButOne(List<MediaFile> group)
    {
        var newest = group.OrderByDescending(f => f.CreatedAt).First();

        foreach (var f in group)
            f.Status = f == newest
                ? MediaFileStatus.ToKeep
                : MediaFileStatus.ToDelete;
    }

    void DeleteAllDuplicatesGlobally()
    {
        foreach (var group in DuplicateService.DuplicateGroups)
        {
            var newest = group.OrderByDescending(f => f.CreatedAt).First();

            foreach (var f in group)
                if (f != newest)
                    f.Status = MediaFileStatus.ToDelete;
        }
    }

    void PrevPage()
    {
        DuplicateService.CurrentPage--;
    }

    void NextPage()
    {
        DuplicateService.CurrentPage++;
    }

    void Continue()
    {
        DuplicateService.DuplicatesHandled = true;
        Navigation.NavigateTo("/");
    }

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.#} {sizes[order]}";
    }
}