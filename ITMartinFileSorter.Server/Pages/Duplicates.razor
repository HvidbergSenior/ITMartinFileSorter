@page "/duplicates"
@using ITMartinFileSorter.Application.Services
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">
    <h4>Handle Duplicates</h4>

    @if (!HasDuplicates)
    {
        <div class="alert alert-success">
            No duplicates found
            <button class="btn btn-primary ms-2" @onclick="Continue">Continue</button>
        </div>
    }
    else
    {
        @foreach (var group in DuplicateService.DuplicateGroups.Where(g => g.Count > 1))
        {
            <div class="border p-2 mb-2">
                @foreach (var file in group)
                {
                    <div>@file.FileName</div>
                }
            </div>
        }

        <button class="btn btn-success mt-3" @onclick="Continue">Continue</button>
    }
</div>

@code {
    bool HasDuplicates => DuplicateService.DuplicateGroups.Any(g => g.Count > 1);

    protected override void OnInitialized()
    {
        if (!HasDuplicates)
        {
            DuplicateService.DuplicatesHandled = true;
        }
    }

    void Continue()
    {
        DuplicateService.DuplicatesHandled = true;
        Navigation.NavigateTo("/");
    }
}