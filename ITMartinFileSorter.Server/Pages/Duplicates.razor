@page "/duplicates"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Application.UseCases
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">
    <h4>Handle Duplicates</h4>

    @if (!HasDuplicates)
    {
        <div class="alert alert-success">
            No duplicates found
            <button class="btn btn-primary ms-2" @onclick="Continue">Continue</button>
        </div>
    }
    else
    {
        @foreach (var category in CategoryOrder)
        {
            var groups = DuplicateService.AllFiles
                .Where(f => f.MainCategory == category)
                .GroupBy(f => f.Hash)
                .Where(g => g.Count() > 1)
                .ToList();

            if (!groups.Any())
                continue;

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 style="color:@GetMainColor(category)">@category</h5>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteAllInCategory(category)">
                        Delete All in Category
                    </button>
                </div>

                @foreach (var group in groups)
                {
                    <div class="d-flex gap-2 flex-wrap mb-3 align-items-center">
                        @foreach (var file in group)
                        {
                            <div class="file-card text-center p-2" style="width:120px; border:1px solid #ccc;">
                                @if (file.MainCategory == MediaMainCategory.Image)
                                {
                                    <img src="@file.ThumbnailPath"
                                         alt="@file.FileName"
                                         style="width:100%; height:80px; object-fit:cover;" />
                                }
                                else if (file.MainCategory == MediaMainCategory.Video)
                                {
                                    <div style="width:100%; height:80px; background:#000; color:#fff; display:flex; align-items:center; justify-content:center;">
                                        VIDEO
                                    </div>
                                }
                                else if (file.MainCategory == MediaMainCategory.Audio)
                                {
                                    <div style="width:100%; height:80px; background:#f0f0f0; display:flex; align-items:center; justify-content:center;">
                                        AUDIO
                                    </div>
                                }
                                else
                                {
                                    <div style="width:100%; height:80px; background:#e0e0e0; display:flex; align-items:center; justify-content:center;">
                                        DOC
                                    </div>
                                }

                                <div style="font-size:0.75em;">@Path.GetFileName(file.FullPath)</div>

                                <button class="btn btn-sm btn-success mt-1 me-1" @onclick="() => Keep(file)">Keep</button>
                                <button class="btn btn-sm btn-danger mt-1" @onclick="() => Delete(file)">Delete</button>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteOneInGroup(group)">
                            Delete One in This Duplicate Group
                        </button>
                    </div>
                }
            </div>
        }

        <!-- Continue is disabled until all duplicate groups handled -->
        <button class="btn btn-success mt-3" @onclick="Continue" disabled="@(!AllGroupsHandled)">
            Continue
        </button>

        @if (!AllGroupsHandled)
        {
            <div class="text-danger mt-2">
                ⚠ You must handle (keep or delete) all duplicates before continuing.
            </div>
        }
    }
</div>

@code {
    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    bool HasDuplicates => DuplicateService.AllFiles.Any(f => !f.Keep);

    bool AllGroupsHandled
    {
        get
        {
            // For each group of duplicates, at least one file must be kept
            return DuplicateService.DuplicateGroups
                .All(g => g.Any(f => f.Keep) || g.All(f => !DuplicateService.AllFiles.Contains(f)));
        }
    }

    string GetMainColor(MediaMainCategory main) => main switch
    {
        MediaMainCategory.Video => "#dc3545",
        MediaMainCategory.Image => "#28a745",
        MediaMainCategory.Audio => "#ffc107",
        MediaMainCategory.Document => "#0d6efd",
        _ => "#6c757d"
    };

    void Keep(MediaFile file)
    {
        file.Keep = true;
        DuplicateService.DuplicateGroups = RebuildGroups();
    }

    void Delete(MediaFile file)
    {
        file.Keep = false;
        DuplicateService.AllFiles.Remove(file);
        DuplicateService.DuplicateGroups = RebuildGroups();
    }

    void DeleteAllInCategory(MediaMainCategory category)
    {
        var toDelete = DuplicateService.AllFiles
            .Where(f => f.MainCategory == category)
            .ToList();

        foreach (var file in toDelete)
        {
            file.Keep = false;
            DuplicateService.AllFiles.Remove(file);
        }

        DuplicateService.DuplicateGroups = RebuildGroups();
    }

    void DeleteOneInGroup(IGrouping<string, MediaFile> group)
    {
        var file = group.FirstOrDefault(f => !f.Keep);
        if (file != null)
        {
            Delete(file);
        }
    }

    void Continue()
    {
        DuplicateService.DuplicatesHandled = true;
        Navigation.NavigateTo("/");
    }

    List<List<MediaFile>> RebuildGroups()
    {
        var finder = new DuplicateFinder();
        return finder.FindDuplicates(DuplicateService.AllFiles).Values.ToList();
    }
}