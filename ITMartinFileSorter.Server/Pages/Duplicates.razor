@page "/duplicates"
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums
@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">
    <h4>Handle Duplicates</h4>

    @if (!HasDuplicates)
    {
        <div class="alert alert-success">
            No duplicates found
            <button class="btn btn-primary ms-2" @onclick="Continue">Continue</button>
        </div>
    }
    else
    {
        <button class="btn btn-danger mb-3" @onclick="DeleteAllDuplicatesGlobally">
            Delete All Duplicates (Keep Newest)
        </button>

        @foreach (var category in CategoryOrder)
        {
            var groups = DuplicateService.AllFiles
                .Where(f => f.MainCategory == category)
                .GroupBy(f => f.Hash)
                .Where(g => g.Count() > 1)
                .ToList();

            if (!groups.Any()) continue;

            <div class="mb-4">
                <h5 style="color:@GetMainColor(category)">@category</h5>

                @foreach (var group in groups)
                {
                    <div class="d-flex gap-2 flex-wrap mb-2">
                        @foreach (var file in group)
                        {
                            <div class="file-card text-center p-2"
                                 style="width:120px; border:1px solid #ccc; @(file.Status == MediaFileStatus.ToDelete ? "opacity:0.5;" : "")">

                                <div style="height:60px; display:flex; align-items:center; justify-content:center;">
                                    <img src="@file.ThumbnailPath" style="max-height:50px; max-width:100%;" />
                                </div>

                                <div style="font-size:0.75em;">@file.FileName</div>

                                <div class="mt-1 d-flex flex-column gap-1">
                                    @if (file.Status == MediaFileStatus.Initial)
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => Keep(file)">Keep</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(file)">Delete</button>
                                    }
                                    else if (file.Status == MediaFileStatus.ToDelete)
                                    {
                                        <div style="color:red; font-size:0.7em;">Marked Delete</div>
                                    }
                                    else if (file.Status == MediaFileStatus.ToKeep)
                                    {
                                        <div style="color:green; font-size:0.7em;">Marked Keep</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <button class="btn btn-sm btn-danger mb-3"
                            @onclick="() => DeleteAllButOne(group)">
                        Delete All But One
                    </button>
                }
            </div>
        }

        <button class="btn btn-success mt-3"
                @onclick="Continue"
                disabled="@(!AllGroupsHandled)">
            Continue
        </button>

        @if (!AllGroupsHandled)
        {
            <div class="text-danger mt-2">
                ⚠ You must handle all duplicate groups
            </div>
        }
    }
</div>

@code {
    readonly MediaMainCategory[] CategoryOrder = new[]
    {
        MediaMainCategory.Image,
        MediaMainCategory.Video,
        MediaMainCategory.Audio,
        MediaMainCategory.Document
    };

    bool HasDuplicates =>
        DuplicateService.AllFiles.GroupBy(f => f.Hash).Any(g => g.Count() > 1);

    bool AllGroupsHandled =>
        DuplicateService.AllFiles
            .GroupBy(f => f.Hash)
            .Where(g => g.Count() > 1)
            .All(g => g.Count(f => f.Status == MediaFileStatus.ToDelete) == g.Count() - 1);

    string GetMainColor(MediaMainCategory main) => main switch
    {
        MediaMainCategory.Video => "#dc3545",
        MediaMainCategory.Image => "#28a745",
        MediaMainCategory.Audio => "#ffc107",
        MediaMainCategory.Document => "#0d6efd",
        _ => "#6c757d"
    };

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;
        StateHasChanged();
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;
        StateHasChanged();
    }

    void DeleteAllButOne(IGrouping<string, MediaFile> group)
    {
        var newest = group.OrderByDescending(f => f.CreatedAt).First();
        foreach (var file in group)
        {
            file.Status = file == newest ? MediaFileStatus.ToKeep : MediaFileStatus.ToDelete;
        }
        StateHasChanged();
    }

    void DeleteAllDuplicatesGlobally()
    {
        foreach (var group in DuplicateService.AllFiles
                     .GroupBy(f => f.Hash)
                     .Where(g => g.Count() > 1))
        {
            var newest = group.OrderByDescending(f => f.CreatedAt).First();
            foreach (var file in group)
            {
                if (file != newest) file.Status = MediaFileStatus.ToDelete;
            }
        }
        StateHasChanged();
    }

    void Continue()
    {
        DuplicateService.DuplicatesHandled = true;
        Navigation.NavigateTo("/");
    }
}